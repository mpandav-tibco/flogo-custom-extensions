{
  "name": "tibco-vectordb-scroll",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/milindpandav/flogo-extensions/vectordb/activity/scrollDocuments",
  "title": "VectorDB: Scroll Documents",
  "description": "Paginate through documents in a collection without a query vector. Ideal for agentic memory iteration.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/scroll.png"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": [
        "vectordb-connector"
      ]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Collection",
        "description": "Fallback collection name when not supplied in the activity input"
      }
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string",
      "display": {
        "name": "Collection Name"
      }
    },
    {
      "name": "limit",
      "type": "integer",
      "display": {
        "name": "Page Size",
        "description": "Documents per page (default: 100)"
      }
    },
    {
      "name": "offset",
      "type": "string",
      "display": {
        "name": "Offset",
        "description": "Continuation token from previous page (nextOffset)"
      }
    },
    {
      "name": "filters",
      "type": "object",
      "display": {
        "name": "Filters"
      }
    },
    {
      "name": "withVectors",
      "type": "boolean",
      "display": {
        "name": "Include Vectors"
      }
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "documents",
      "type": "array"
    },
    {
      "name": "nextOffset",
      "type": "string",
      "display": {
        "name": "Next Offset",
        "description": "Pass to offset input of next call for pagination"
      }
    },
    {
      "name": "total",
      "type": "integer"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
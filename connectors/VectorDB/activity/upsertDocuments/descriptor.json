{
  "name": "tibco-vectordb-upsert",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/milindpandav/flogo-extensions/vectordb/activity/upsertDocuments",
  "title": "VectorDB: Upsert Documents",
  "description": "Insert or update documents (vectors + metadata) in the configured VectorDB collection.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/upsert.png",
    "description": "Upsert documents into a VectorDB collection"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": [
        "vectordb-connector"
      ]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Collection",
        "description": "Fallback collection name when not supplied in the activity input"
      }
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string",
      "display": {
        "name": "Collection Name",
        "description": "Target collection; overrides defaultCollection"
      }
    },
    {
      "name": "documents",
      "type": "array",
      "display": {
        "name": "Documents",
        "description": "Array of {id, vector, content, ...payload} objects"
      }
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "upsertedCount",
      "type": "integer"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
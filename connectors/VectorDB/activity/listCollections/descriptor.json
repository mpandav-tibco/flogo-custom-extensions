      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": []
    }
  ],
  "input": [],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "collections",
      "type": "array",
      "schema": "{\"type\": \"array\", \"items\": {\"type\": \"string\"}}"
    },
    {
      "name": "totalCount",
      "type": "integer"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]

{
  "name": "tibco-vectordb-list-cols",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb/activity/listCollections",
  "title": "List Collections",
  "image": "icons/list.svg",
  "description": "List all collections / indexes available in the connected VectorDB.",
  "display": {
    "category": "VectorDB",

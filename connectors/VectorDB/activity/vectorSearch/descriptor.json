{
  "name": "tibco-vectordb-search",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/milindpandav/flogo-extensions/vectordb/activity/vectorSearch",
  "title": "VectorDB: Vector Search",
  "description": "Semantic vector similarity search in a VectorDB collection.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/search.png",
    "description": "Semantic vector search (dense ANN)"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": [
        "vectordb-connector"
      ]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Collection",
        "description": "Fallback collection name when not supplied in the activity input"
      }
    },
    {
      "name": "defaultTopK",
      "type": "integer",
      "required": false,
      "value": 10,
      "display": {
        "name": "Default Top-K",
        "description": "Default number of results when not supplied in the activity input"
      }
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string",
      "display": {
        "name": "Collection Name"
      }
    },
    {
      "name": "queryVector",
      "type": "array",
      "display": {
        "name": "Query Vector",
        "description": "Float64 embedding vector"
      }
    },
    {
      "name": "topK",
      "type": "integer",
      "display": {
        "name": "Top K",
        "description": "Number of results (default: defaultTopK or 10)"
      }
    },
    {
      "name": "scoreThreshold",
      "type": "number",
      "display": {
        "name": "Score Threshold",
        "description": "Minimum similarity score (0\u20131)"
      }
    },
    {
      "name": "filters",
      "type": "object",
      "display": {
        "name": "Filters",
        "description": "Key-value filter map applied to payload"
      }
    },
    {
      "name": "withVectors",
      "type": "boolean",
      "display": {
        "name": "Include Vectors",
        "description": "Return embedding vectors in results"
      }
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "results",
      "type": "array",
      "display": {
        "name": "Search Results"
      }
    },
    {
      "name": "totalCount",
      "type": "integer"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
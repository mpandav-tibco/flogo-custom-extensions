{
  "name": "tibco-vectordb-create-col",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb/activity/createCollection",
  "title": "Create Collection",
  "image": "icons/collection.svg",
  "description": "Create a new vector collection / index in the connected VectorDB.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/collection.svg"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": []
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string"
    },
    {
      "name": "dimensions",
      "type": "integer",
      "value": 1536
    },
    {
      "name": "distanceMetric",
      "type": "string",
      "value": "cosine",
      "allowed": [
        "cosine",
        "euclidean",
        "dot"
      ]
    },
    {
      "name": "onDisk",
      "type": "boolean",
      "value": false
    },
    {
      "name": "replicationFactor",
      "type": "integer",
      "value": 1
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
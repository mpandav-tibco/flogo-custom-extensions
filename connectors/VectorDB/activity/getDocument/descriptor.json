{
  "name": "tibco-vectordb-get-doc",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/milindpandav/flogo-extensions/vectordb/activity/getDocument",
  "title": "VectorDB: Get Document",
  "description": "Retrieve a single document by its ID.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/get.png"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": [
        "vectordb-connector"
      ]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Collection",
        "description": "Fallback collection name when not supplied in the activity input"
      }
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string",
      "display": {
        "name": "Collection Name"
      }
    },
    {
      "name": "documentId",
      "type": "string",
      "display": {
        "name": "Document ID"
      }
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "document",
      "type": "object",
      "display": {
        "name": "Document"
      }
    },
    {
      "name": "found",
      "type": "boolean",
      "display": {
        "name": "Found",
        "description": "False if document does not exist (not an error)"
      }
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
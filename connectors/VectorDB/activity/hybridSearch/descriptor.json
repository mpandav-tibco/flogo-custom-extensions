{
  "name": "tibco-vectordb-hybrid-search",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/milindpandav/flogo-extensions/vectordb/activity/hybridSearch",
  "title": "VectorDB: Hybrid Search",
  "description": "Hybrid (dense vector + BM25 keyword) search. Alpha=1 is pure vector, Alpha=0 is pure BM25.",
  "display": {
    "category": "VectorDB",
    "visible": true,
    "smallIcon": "icons/hybrid.png",
    "description": "Hybrid dense+sparse search for improved RAG recall"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "VectorDB Connection",
        "description": "Select the VectorDB connector to use",
        "type": "connection"
      },
      "allowed": [
        "vectordb-connector"
      ]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Collection",
        "description": "Fallback collection name when not supplied in the activity input"
      }
    },
    {
      "name": "defaultTopK",
      "type": "integer",
      "required": false,
      "value": 10,
      "display": {
        "name": "Default Top-K",
        "description": "Default number of results when not supplied in the activity input"
      }
    }
  ],
  "input": [
    {
      "name": "collectionName",
      "type": "string",
      "display": {
        "name": "Collection Name"
      }
    },
    {
      "name": "queryText",
      "type": "string",
      "display": {
        "name": "Query Text",
        "description": "Text query for BM25 / keyword search"
      }
    },
    {
      "name": "queryVector",
      "type": "array",
      "display": {
        "name": "Query Vector",
        "description": "Dense embedding vector"
      }
    },
    {
      "name": "topK",
      "type": "integer",
      "display": {
        "name": "Top K"
      }
    },
    {
      "name": "scoreThreshold",
      "type": "number",
      "display": {
        "name": "Score Threshold"
      }
    },
    {
      "name": "alpha",
      "type": "number",
      "display": {
        "name": "Alpha",
        "description": "Balance between vector (1.0) and keyword (0.0). Default 0.5"
      }
    },
    {
      "name": "filters",
      "type": "object",
      "display": {
        "name": "Filters"
      }
    }
  ],
  "output": [
    {
      "name": "success",
      "type": "boolean"
    },
    {
      "name": "results",
      "type": "array"
    },
    {
      "name": "totalCount",
      "type": "integer"
    },
    {
      "name": "duration",
      "type": "string"
    },
    {
      "name": "error",
      "type": "string"
    }
  ]
}
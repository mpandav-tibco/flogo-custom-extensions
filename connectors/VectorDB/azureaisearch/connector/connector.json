{
    "name": "azureaisearch-connector",
    "title": "Azure AI Search Connector",
    "version": "1.0.0",
    "type": "flogo:connector",
    "image": "icons/vectordb.svg",
    "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb-azureaisearch/connector",
    "display": {
        "category": "VectorDB",
        "visible": true,
        "connectionsupport": true,
        "smallIcon": "icons/vectordb.svg",
        "description": "Azure AI Search vector database connector for semantic search and RAG"
    },
    "keyfield": "name",
    "settings": [
        {
            "name": "name",
            "type": "string",
            "required": true,
            "display": {
                "name": "Connection Name",
                "description": "Unique name for this connection (used as registry key)",
                "appPropertySupport": true
            }
        },
        {
            "name": "endpoint",
            "type": "string",
            "required": true,
            "display": {
                "name": "Endpoint",
                "description": "Azure AI Search service endpoint, e.g. https://myservice.search.windows.net",
                "appPropertySupport": true
            }
        },
        {
            "name": "apiKey",
            "type": "string",
            "required": true,
            "display": {
                "name": "Admin API Key",
                "description": "Azure AI Search admin API key. Use $property[MY_KEY] to inject at runtime.",
                "type": "password",
                "appPropertySupport": true
            }
        },
        {
            "name": "apiVersion",
            "type": "string",
            "required": false,
            "value": "2024-05-01-Preview",
            "display": {
                "name": "API Version",
                "description": "Azure AI Search REST API version (default: 2024-05-01-Preview)",
                "appPropertySupport": true
            }
        },
        {
            "name": "timeoutSeconds",
            "type": "integer",
            "required": false,
            "value": 30,
            "display": {
                "name": "Timeout (seconds)",
                "description": "Per-operation timeout in seconds (default: 30)"
            }
        },
        {
            "name": "maxRetries",
            "type": "integer",
            "required": false,
            "value": 3,
            "display": {
                "name": "Max Retries",
                "description": "Maximum retries on transient errors (default: 3)"
            }
        },
        {
            "name": "retryBackoffMs",
            "type": "integer",
            "required": false,
            "value": 500,
            "display": {
                "name": "Retry Backoff (ms)",
                "description": "Milliseconds to wait between retries (default: 500)"
            }
        },
        {
            "name": "enableEmbedding",
            "type": "boolean",
            "required": false,
            "value": false,
            "display": {
                "name": "Configure Embedding Provider",
                "description": "Enable shared AI embedding configuration for this connection.",
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingProvider",
            "type": "string",
            "required": false,
            "value": "OpenAI",
            "allowed": [
                "OpenAI",
                "Azure OpenAI",
                "Cohere",
                "Ollama",
                "Custom"
            ],
            "display": {
                "name": "Embedding Provider",
                "description": "AI service used to generate vector embeddings",
                "type": "dropdown",
                "selection": "single",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingAPIKey",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding API Key",
                "description": "API key for the embedding service.",
                "type": "password",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingBaseURL",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding Base URL",
                "description": "Override the default provider endpoint.",
                "visible": false,
                "appPropertySupport": true
            }
        }
    ],
    "actions": [
        {
            "name": "Connect"
        }
    ]
}

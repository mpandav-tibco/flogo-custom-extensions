{
  "name": "tibco-vectordb-azureaisearch-search",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb-azureaisearch/activity/vectorSearch",
  "title": "Vector Search",
  "image": "icons/search.svg",
  "description": "Semantic vector similarity search in an Azure AI Search index.",
  "display": {
    "category": "azureaisearch",
    "visible": true,
    "smallIcon": "icons/search.svg",
    "description": "Semantic vector search (dense ANN)"
  },
  "settings": [
    {
      "name": "connection",
      "type": "connection",
      "required": true,
      "display": {
        "name": "Azure AI Search Connection",
        "description": "Select the Azure AI Search connector to use",
        "type": "connection"
      },
      "allowed": ["azureaisearch-connector"]
    },
    {
      "name": "defaultCollection",
      "type": "string",
      "required": false,
      "display": {
        "name": "Default Index",
        "description": "Fallback index name when not provided in the activity input",
        "appPropertySupport": true
      }
    },
    {
      "name": "defaultTopK",
      "type": "integer",
      "required": false,
      "value": 10,
      "display": {
        "name": "Default Top-K",
        "description": "Default number of results when not provided in the activity input",
        "appPropertySupport": true
      }
    }
  ],
  "input": [
    {"name": "collectionName", "type": "string"},
    {"name": "queryVector", "type": "array", "schema": "{\"type\": \"array\", \"items\": {\"type\": \"number\"}}"},
    {"name": "topK", "type": "integer", "value": 0},
    {"name": "scoreThreshold", "type": "number", "value": 0.0},
    {"name": "filters", "type": "object"},
    {"name": "withVectors", "type": "boolean", "value": false},
    {"name": "skipPayload", "type": "boolean", "value": false}
  ],
  "output": [
    {"name": "success", "type": "boolean"},
    {"name": "results", "type": "array"},
    {"name": "totalCount", "type": "integer"},
    {"name": "duration", "type": "string"},
    {"name": "error", "type": "string"}
  ]
}

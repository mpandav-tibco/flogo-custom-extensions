{
    "name": "pinecone-connector",
    "title": "Pinecone Connector",
    "version": "1.0.0",
    "type": "flogo:connector",
    "image": "icons/vectordb.svg",
    "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb-pinecone/connector",
    "display": {
        "category": "VectorDB",
        "visible": true,
        "connectionsupport": true,
        "smallIcon": "icons/vectordb.svg",
        "description": "Pinecone vector database connector — cloud or local development"
    },
    "keyfield": "name",
    "settings": [
        {
            "name": "name",
            "type": "string",
            "required": true,
            "display": {
                "name": "Connection Name",
                "description": "Unique name for this connection (used as registry key)",
                "appPropertySupport": true
            }
        },
        {
            "name": "scheme",
            "type": "string",
            "required": false,
            "value": "https",
            "allowed": ["https", "http"],
            "display": {
                "name": "Mode",
                "description": "https = Pinecone Cloud (production). http = Pinecone Local (Docker, no API key required).",
                "type": "dropdown",
                "selection": "single",
                "appPropertySupport": true
            }
        },
        {
            "name": "host",
            "type": "string",
            "required": false,
            "value": "",
            "display": {
                "name": "Control-Plane Host",
                "description": "Leave blank for Pinecone Cloud (uses api.pinecone.io). For Pinecone Local set to localhost:5080.",
                "appPropertySupport": true
            }
        },
        {
            "name": "apiKey",
            "type": "string",
            "required": false,
            "display": {
                "name": "API Key",
                "description": "Pinecone API key. Required for cloud mode (https). Leave blank or use any value for Pinecone Local (http) — the local emulator ignores it.",
                "type": "password",
                "appPropertySupport": true
            }
        },
        {
            "name": "pineconeCloud",
            "type": "string",
            "required": false,
            "value": "aws",
            "allowed": ["aws", "gcp", "azure"],
            "display": {
                "name": "Cloud Provider",
                "description": "Cloud provider for new serverless indexes (cloud mode only): aws, gcp, azure",
                "type": "dropdown",
                "selection": "single",
                "appPropertySupport": true
            }
        },
        {
            "name": "pineconeRegion",
            "type": "string",
            "required": false,
            "value": "us-east-1",
            "display": {
                "name": "Region",
                "description": "Cloud region for new serverless indexes (cloud mode only), e.g. us-east-1",
                "appPropertySupport": true
            }
        },
        {
            "name": "timeoutSeconds",
            "type": "integer",
            "required": false,
            "value": 30,
            "display": {
                "name": "Timeout (seconds)",
                "description": "Per-operation timeout in seconds (default: 30)",
                "appPropertySupport": true
            }
        },
        {
            "name": "maxRetries",
            "type": "integer",
            "required": false,
            "value": 3,
            "display": {
                "name": "Max Retries",
                "description": "Maximum retries on transient errors (default: 3)",
                "appPropertySupport": true
            }
        },
        {
            "name": "retryBackoffMs",
            "type": "integer",
            "required": false,
            "value": 500,
            "display": {
                "name": "Retry Backoff (ms)",
                "description": "Milliseconds to wait between retries (default: 500)",
                "appPropertySupport": true
            }
        },
        {
            "name": "enableEmbedding",
            "type": "boolean",
            "required": false,
            "value": false,
            "display": {
                "name": "Configure Embedding Provider",
                "description": "Enable shared AI embedding configuration for this connection. When checked, activities (RAG Query, Ingest Documents) can inherit the provider, API key, and base URL from here — so you only set the secret once.",
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingProvider",
            "type": "string",
            "required": false,
            "value": "OpenAI",
            "allowed": [
                "OpenAI",
                "Azure OpenAI",
                "Cohere",
                "Ollama",
                "Custom"
            ],
            "display": {
                "name": "Embedding Provider",
                "description": "AI service used to generate vector embeddings",
                "type": "dropdown",
                "selection": "single",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingAPIKey",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding API Key",
                "description": "API key for the embedding service. Use $property[MY_KEY] to inject from an app property at runtime — the secret never appears in flogo.json.",
                "type": "password",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingBaseURL",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding Base URL",
                "description": "Override the default provider endpoint. Azure: full deployment URL. Ollama: http://localhost:11434. Custom: your endpoint. Leave blank for default OpenAI / Cohere endpoints.",
                "visible": false,
                "appPropertySupport": true
            }
        }
    ],
    "actions": [
        {
            "name": "Connect"
        }
    ]
}

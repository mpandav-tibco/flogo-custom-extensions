{
    "name": "pgvector-connector",
    "title": "pgvector Connector",
    "version": "1.0.0",
    "type": "flogo:connector",
    "image": "icons/vectordb.svg",
    "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb-pgvector/connector",
    "display": {
        "category": "VectorDB",
        "visible": true,
        "connectionsupport": true,
        "smallIcon": "icons/vectordb.svg",
        "description": "PostgreSQL pgvector connector for vector similarity search"
    },
    "keyfield": "name",
    "settings": [
        {
            "name": "name",
            "type": "string",
            "required": true,
            "display": {
                "name": "Connection Name",
                "description": "Unique name for this connection (used as registry key)",
                "appPropertySupport": true
            }
        },
        {
            "name": "host",
            "type": "string",
            "required": true,
            "display": {
                "name": "Host",
                "description": "Hostname or IP address of the PostgreSQL server",
                "appPropertySupport": true
            }
        },
        {
            "name": "port",
            "type": "integer",
            "required": false,
            "value": 5432,
            "display": {
                "name": "Port",
                "description": "TCP port for PostgreSQL (default: 5432)",
                "appPropertySupport": true
            }
        },
        {
            "name": "username",
            "type": "string",
            "required": true,
            "display": {
                "name": "Username",
                "description": "PostgreSQL username",
                "appPropertySupport": true
            }
        },
        {
            "name": "password",
            "type": "string",
            "required": false,
            "display": {
                "name": "Password",
                "description": "PostgreSQL password",
                "type": "password",
                "appPropertySupport": true
            }
        },
        {
            "name": "dbName",
            "type": "string",
            "required": false,
            "value": "postgres",
            "display": {
                "name": "Database Name",
                "description": "PostgreSQL database name (default: postgres)",
                "appPropertySupport": true
            }
        },
        {
            "name": "sslMode",
            "type": "string",
            "required": false,
            "value": "disable",
            "allowed": ["disable", "require", "verify-ca", "verify-full"],
            "display": {
                "name": "SSL Mode",
                "description": "PostgreSQL SSL/TLS mode (default: disable)",
                "type": "dropdown",
                "selection": "single",
                "appPropertySupport": true
            }
        },
        {
            "name": "timeoutSeconds",
            "type": "integer",
            "required": false,
            "value": 30,
            "display": {
                "name": "Timeout (seconds)",
                "description": "Per-operation timeout in seconds (default: 30)",
                "appPropertySupport": true
            }
        },
        {
            "name": "maxRetries",
            "type": "integer",
            "required": false,
            "value": 3,
            "display": {
                "name": "Max Retries",
                "description": "Maximum retries on transient errors (default: 3)",
                "appPropertySupport": true
            }
        },
        {
            "name": "retryBackoffMs",
            "type": "integer",
            "required": false,
            "value": 500,
            "display": {
                "name": "Retry Backoff (ms)",
                "description": "Milliseconds to wait between retries (default: 500)",
                "appPropertySupport": true
            }
        },
        {
            "name": "enableEmbedding",
            "type": "boolean",
            "required": false,
            "value": false,
            "display": {
                "name": "Configure Embedding Provider",
                "description": "Enable shared AI embedding configuration for this connection",
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingProvider",
            "type": "string",
            "required": false,
            "value": "OpenAI",
            "allowed": ["OpenAI", "Azure OpenAI", "Cohere", "Ollama", "Custom"],
            "display": {
                "name": "Embedding Provider",
                "description": "AI service used to generate vector embeddings",
                "type": "dropdown",
                "selection": "single",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingAPIKey",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding API Key",
                "description": "API key for the embedding service",
                "type": "password",
                "visible": false,
                "appPropertySupport": true
            }
        },
        {
            "name": "embeddingBaseURL",
            "type": "string",
            "required": false,
            "display": {
                "name": "Embedding Base URL",
                "description": "Override the default provider endpoint",
                "visible": false,
                "appPropertySupport": true
            }
        }
    ],
    "actions": [
        {
            "name": "Connect"
        }
    ]
}

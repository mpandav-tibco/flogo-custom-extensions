{
  "name": "tibco-vectordb-delete-docs",
  "version": "1.0.0",
  "type": "flogo:activity",
  "ref": "github.com/mpandav-tibco/flogo-extensions/vectordb-elasticsearch/activity/deleteDocuments",
  "title": "Delete Documents",
  "image": "icons/delete.svg",
  "description": "Delete documents by ID list or by filter expression.",
  "display": {"category": "elasticsearch","visible": true,"smallIcon": "icons/delete.svg"},
  "settings": [
    {"name": "connection","type": "connection","required": true,"display": {"name": "VectorDB Connection","description": "Select the VectorDB connector to use","type": "connection"},"allowed": ["elasticsearch-connector"]},
    {"name": "defaultCollection","type": "string","required": false,"display": {"name": "Default Collection","description": "Fallback collection name","appPropertySupport": true}}
  ],
  "input": [
    {"name": "collectionName","type": "string"},
    {"name": "ids","type": "array","schema": "{\"type\": \"array\", \"items\": {\"type\": \"string\"}}"},
    {"name": "filters","type": "object","schema": "{\"type\": \"object\", \"additionalProperties\": true}"}
  ],
  "output": [
    {"name": "success","type": "boolean"},
    {"name": "deletedCount","type": "integer"},
    {"name": "duration","type": "string"},
    {"name": "error","type": "string"}
  ]
}

{
    "name": "util",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Utility Functions",
    "description": "General-purpose utility functions: coalesce, sha256",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/util",
    "functions": [
        {
            "name": "coalesce",
            "description": "Returns the first non-nil, non-empty argument. Accepts any number of arguments. util.coalesce(nil, \"\", \"hello\") => \"hello\"",
            "example": "util.coalesce($flow.optional, \"default\")",
            "args": [
                {
                    "name": "values",
                    "type": "any"
                }
            ],
            "varArgs": true,
            "return": {
                "type": "any"
            }
        },
        {
            "name": "sha256",
            "description": "Returns the lowercase hex-encoded SHA-256 hash of the input string. Useful for idempotency keys and checksums. util.sha256(\"hello\") => \"2cf24dba...\"",
            "example": "util.sha256(\"hello\") => \"2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        }
    ]
}
{
    "name": "string",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Extended String Functions",
    "description": "Additional string functions not available in the built-in set: padLeft, padRight, mask",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/string",
    "functions": [
        {
            "name": "padLeft",
            "description": "Pads str on the left with padChar until the string reaches the target size. Only the first character of padChar is used. string.padLeft(\"7\", 3, \"0\") => \"007\"",
            "example": "string.padLeft(\"7\", 3, \"0\") => \"007\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "size",
                    "type": "integer"
                },
                {
                    "name": "padChar",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "padRight",
            "description": "Pads str on the right with padChar until the string reaches the target size. Only the first character of padChar is used. string.padRight(\"hi\", 5, \"-\") => \"hi---\"",
            "example": "string.padRight(\"hi\", 5, \"-\") => \"hi---\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "size",
                    "type": "integer"
                },
                {
                    "name": "padChar",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "mask",
            "description": "Replaces the middle portion of str with '*', preserving keepFirst characters at the start and keepLast characters at the end. string.mask(\"4111-1111-1111-1234\", 0, 4) => \"***************1234\"",
            "example": "string.mask(\"john.doe@acme.com\", 1, 9) => \"j*******@acme.com\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "keepFirst",
                    "type": "integer"
                },
                {
                    "name": "keepLast",
                    "type": "integer"
                }
            ],
            "return": {
                "type": "string"
            }
        }
    ]
}
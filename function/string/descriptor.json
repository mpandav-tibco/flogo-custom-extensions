{
    "name": "string",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Extended String Functions",
    "description": "Additional string functions not available in the built-in set: padLeft, padRight, mask, truncate, isBlank, isNumeric, camelCase, snakeCase",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/string",
    "functions": [
        {
            "name": "padLeft",
            "description": "Pads str on the left with padChar until the string reaches the target size. Only the first character of padChar is used.",
            "example": "string.padLeft(\"7\", 3, \"0\") => \"007\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "size",
                    "type": "int"
                },
                {
                    "name": "padChar",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "padRight",
            "description": "Pads str on the right with padChar until the string reaches the target size. Only the first character of padChar is used.",
            "example": "string.padRight(\"hi\", 5, \"-\") => \"hi---\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "size",
                    "type": "int"
                },
                {
                    "name": "padChar",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "mask",
            "description": "Replaces the middle portion of str with '*', preserving keepFirst characters at the start and keepLast characters at the end.",
            "example": "string.mask(\"john.doe@acme.com\", 1, 9) => \"j*******@acme.com\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "keepFirst",
                    "type": "int"
                },
                {
                    "name": "keepLast",
                    "type": "int"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "truncate",
            "description": "Truncates str to maxLen characters. If truncated, appends '...' (total length = maxLen).",
            "example": "string.truncate(\"Hello, World!\", 8) => \"Hello...\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "maxLen",
                    "type": "int"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "isBlank",
            "description": "Returns true if str is nil, empty, or contains only whitespace.",
            "example": "string.isBlank(\"  \") => true",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "isNumeric",
            "description": "Returns true if str represents a valid decimal integer or float value.",
            "example": "string.isNumeric(\"3.14\") => true",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "camelCase",
            "description": "Converts str to lowerCamelCase, splitting on spaces, hyphens, underscores, and case transitions.",
            "example": "string.camelCase(\"user_first_name\") => \"userFirstName\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "snakeCase",
            "description": "Converts str to snake_case.",
            "example": "string.snakeCase(\"userFirstName\") => \"user_first_name\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "regexExtract",
            "description": "Extracts the first match of pattern from str. If the pattern has a capture group, returns the first capture group; otherwise returns the full match. Returns empty string if no match. Unlike OOTB string.matchRegEx which only returns bool.",
            "example": "string.regexExtract(\"order-12345\", \"\\\\d+\") => \"12345\"",
            "args": [
                {
                    "name": "str",
                    "type": "string"
                },
                {
                    "name": "pattern",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "format",
            "description": "Formats a template string using fmt.Sprintf-style verbs (%s, %d, %.2f, etc.) with the given arguments.",
            "example": "string.format(\"Hello %s, you have %d messages\", \"Alice\", 3) => \"Hello Alice, you have 3 messages\"",
            "args": [
                {
                    "name": "template",
                    "type": "string"
                },
                {
                    "name": "args",
                    "type": "any"
                }
            ],
            "varArgs": true,
            "return": {
                "type": "string"
            }
        }
    ]
}
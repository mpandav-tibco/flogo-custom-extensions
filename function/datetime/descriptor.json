{
    "name": "datetime",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Extended Datetime Functions",
    "description": "Additional datetime functions not available in the built-in set: isBefore, isAfter, toEpoch, fromEpoch, isWeekend, isWeekday",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/datetime",
    "functions": [
        {
            "name": "isBefore",
            "description": "Returns true if d1 is strictly before d2. Accepts any datetime string parseable by Flogo (RFC3339, ISO 8601, etc.).",
            "example": "datetime.isBefore(\"2024-01-01\", \"2024-06-01\") => true",
            "args": [
                {
                    "name": "d1",
                    "type": "string"
                },
                {
                    "name": "d2",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "isAfter",
            "description": "Returns true if d1 is strictly after d2.",
            "example": "datetime.isAfter(\"2024-06-01\", \"2024-01-01\") => true",
            "args": [
                {
                    "name": "d1",
                    "type": "string"
                },
                {
                    "name": "d2",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "toEpoch",
            "description": "Converts a datetime string to Unix epoch milliseconds (int64).",
            "example": "datetime.toEpoch(\"2024-01-15T10:30:00Z\") => 1705314600000",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                }
            ],
            "return": {
                "type": "integer"
            }
        },
        {
            "name": "fromEpoch",
            "description": "Converts Unix epoch milliseconds to an RFC3339 UTC datetime string.",
            "example": "datetime.fromEpoch(1705314600000) => \"2024-01-15T10:30:00Z\"",
            "args": [
                {
                    "name": "epochMs",
                    "type": "integer"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "isWeekend",
            "description": "Returns true if the given datetime falls on Saturday or Sunday.",
            "example": "datetime.isWeekend(\"2024-01-06\") => true",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "isWeekday",
            "description": "Returns true if the given datetime falls on Monday through Friday.",
            "example": "datetime.isWeekday(\"2024-01-08\") => true",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                }
            ],
            "return": {
                "type": "boolean"
            }
        },
        {
            "name": "addBusinessDays",
            "description": "Adds n business days (Mon–Fri) to the given date, skipping weekends. Negative n moves backward. Returns RFC3339.",
            "example": "datetime.addBusinessDays(\"2024-01-05T00:00:00Z\", 3) => \"2024-01-10T00:00:00Z\"",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                },
                {
                    "name": "days",
                    "type": "int"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "startOfDay",
            "description": "Returns the start of day (00:00:00 UTC) for the given datetime as an RFC3339 string.",
            "example": "datetime.startOfDay(\"2024-03-15T14:30:00Z\") => \"2024-03-15T00:00:00Z\"",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                }
            ],
            "return": {
                "type": "string"
            }
        },
        {
            "name": "quarter",
            "description": "Returns the calendar quarter (1–4) of the given datetime. Jan–Mar=1, Apr–Jun=2, Jul–Sep=3, Oct–Dec=4.",
            "example": "datetime.quarter(\"2024-07-15T00:00:00Z\") => 3",
            "args": [
                {
                    "name": "datetime",
                    "type": "string"
                }
            ],
            "return": {
                "type": "int"
            }
        }
    ]
}
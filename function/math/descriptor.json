{
    "name": "math",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Extended Math Functions",
    "description": "Additional math functions not available in the built-in set: abs, pow, sqrt, log, log2, log10, sign, clamp",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/math",
    "functions": [
        {
            "name": "abs",
            "description": "Returns the absolute value of x. Negative values become positive; positive values are unchanged.",
            "example": "math.abs(-5.5) => 5.5",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "pow",
            "description": "Returns base raised to the power of exp. math.pow(2, 10) => 1024",
            "example": "math.pow(2, 10) => 1024",
            "args": [
                {
                    "name": "base",
                    "type": "number"
                },
                {
                    "name": "exp",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "sqrt",
            "description": "Returns the square root of x. Error if x is negative.",
            "example": "math.sqrt(9) => 3",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "log",
            "description": "Returns the natural logarithm (base e) of x. Error if x <= 0.",
            "example": "math.log(2.718281828) => ~1",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "log2",
            "description": "Returns the base-2 logarithm of x. Error if x <= 0.",
            "example": "math.log2(8) => 3",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "log10",
            "description": "Returns the base-10 logarithm of x. Error if x <= 0.",
            "example": "math.log10(1000) => 3",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "sign",
            "description": "Returns -1 if x < 0, 0 if x == 0, 1 if x > 0.",
            "example": "math.sign(-5) => -1",
            "args": [
                {
                    "name": "x",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        },
        {
            "name": "clamp",
            "description": "Clamps val to the inclusive range [min, max].",
            "example": "math.clamp(150, 0, 100) => 100",
            "args": [
                {
                    "name": "val",
                    "type": "number"
                },
                {
                    "name": "min",
                    "type": "number"
                },
                {
                    "name": "max",
                    "type": "number"
                }
            ],
            "return": {
                "type": "number"
            }
        }
    ]
}
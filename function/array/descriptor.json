{
    "name": "array",
    "type": "flogo:function",
    "version": "1.0.0",
    "title": "Extended Array Functions",
    "description": "Additional array functions: min, max, avg, unique, indexOf, sort, sortDesc, first, last, sumBy, filter, pluck",
    "homepage": "https://github.com/mpandav-tibco/flogo-custom-extensions/tree/main/function/array",
    "functions": [
        {
            "name": "min",
            "description": "Returns the minimum numeric value in the array.",
            "example": "array.min(array.create(3,1,4,1,5)) => 1",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "float64"
            }
        },
        {
            "name": "max",
            "description": "Returns the maximum numeric value in the array.",
            "example": "array.max(array.create(3,1,4,1,5)) => 5",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "float64"
            }
        },
        {
            "name": "avg",
            "description": "Returns the arithmetic mean of all numeric values in the array.",
            "example": "array.avg(array.create(1,2,3,4,5)) => 3",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "float64"
            }
        },
        {
            "name": "unique",
            "description": "Returns a new array with duplicate values removed, preserving original order.",
            "example": "array.unique(array.create(1,2,2,3,1)) => [1,2,3]",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "array",
                "valueType": "any"
            }
        },
        {
            "name": "indexOf",
            "description": "Returns the zero-based index of the first occurrence of value in the array, or -1 if not found.",
            "example": "array.indexOf(array.create(\"a\",\"b\",\"c\"), \"b\") => 1",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                },
                {
                    "name": "value",
                    "type": "any"
                }
            ],
            "return": {
                "type": "int"
            }
        },
        {
            "name": "sort",
            "description": "Returns a new array sorted ascending. Numeric arrays sort numerically; string arrays sort lexicographically.",
            "example": "array.sort(array.create(3,1,2)) => [1,2,3]",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "array",
                "valueType": "any"
            }
        },
        {
            "name": "sortDesc",
            "description": "Returns a new array sorted descending. Numeric arrays sort numerically; string arrays sort lexicographically.",
            "example": "array.sortDesc(array.create(1,3,2)) => [3,2,1]",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "array",
                "valueType": "any"
            }
        },
        {
            "name": "first",
            "description": "Returns the first element of the array, or null if the array is empty.",
            "example": "array.first(array.create(10,20,30)) => 10",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "any"
            }
        },
        {
            "name": "last",
            "description": "Returns the last element of the array, or null if the array is empty.",
            "example": "array.last(array.create(10,20,30)) => 30",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                }
            ],
            "return": {
                "type": "any"
            }
        },
        {
            "name": "sumBy",
            "description": "Sums the value of a named numeric field across an array of objects.",
            "example": "array.sumBy($flow.orders, \"amount\") => 30",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                },
                {
                    "name": "field",
                    "type": "string"
                }
            ],
            "return": {
                "type": "float64"
            }
        },
        {
            "name": "filter",
            "description": "Returns elements from an array of objects where element[field] equals value.",
            "example": "array.filter($flow.users, \"role\", \"admin\") => [{\"name\":\"Alice\",\"role\":\"admin\"}]",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                },
                {
                    "name": "field",
                    "type": "string"
                },
                {
                    "name": "value",
                    "type": "any"
                }
            ],
            "return": {
                "type": "array",
                "valueType": "any"
            }
        },
        {
            "name": "pluck",
            "description": "Extracts the value of a named field from every object in the array and returns them as a flat array.",
            "example": "array.pluck($flow.users, \"email\") => [\"alice@example.com\",\"bob@example.com\"]",
            "args": [
                {
                    "name": "arr",
                    "type": "array",
                    "valueType": "any"
                },
                {
                    "name": "field",
                    "type": "string"
                }
            ],
            "return": {
                "type": "array",
                "valueType": "any"
            }
        }
    ]
}
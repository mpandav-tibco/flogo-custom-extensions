          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"#### TEST Functions : \",coerce.toString($activity[Mapper1]) )",
                "logLevel": ""
              }
            }

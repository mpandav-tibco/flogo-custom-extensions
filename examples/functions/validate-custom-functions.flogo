                    "positiveNum": 42.5,
                    "powBase": 2,
                    "powExp": 10,
                    "compoundBase": 1.025,
                    "compoundExp": 4,
                    "tempReadings": [
                      22.5,
                      19.8,
                      25.1,
                      18.3,
                      23.7,
                      21
                    ],
                    "deviceIds": [
                      "sensor-1",
                      "sensor-2",
                      "sensor-1",
                      "sensor-3",
                      "sensor-2"
                    ],
                    "orderStatuses": [

                    "cardNumber": "4532015112830366",
                    "emailAddress": "alice.wonder@acme.com",
                    "regionOverride": "",
                    "regionDefault": "us-east-1",
                    "invoiceId": "order-2024-INV-0042"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"negativeTemp\":   { \"type\": \"number\",  \"default\": -273.15 },\n    \"positiveNum\":    { \"type\": \"number\",  \"default\": 42.5 },\n    \"powBase\":        { \"type\": \"number\",  \"default\": 2 },\n    \"powExp\":         { \"type\": \"number\",  \"default\": 10 },\n    \"compoundBase\":   { \"type\": \"number\",  \"default\": 1.025 },\n    \"compoundExp\":    { \"type\": \"number\",  \"default\": 4 },\n\n    \"tempReadings\":   { \"type\": \"array\", \"items\": { \"type\": \"number\" },  \"default\": [22.5, 19.8, 25.1, 18.3, 23.7, 21.0] },\n    \"deviceIds\":      { \"type\": \"array\", \"items\": { \"type\": \"string\" },  \"default\": [\"sensor-1\",\"sensor-2\",\"sensor-1\",\"sensor-3\",\"sensor-2\"] },\n    \"orderStatuses\":  { \"type\": \"array\", \"items\": { \"type\": \"string\" },  \"default\": [\"pending\",\"processing\",\"shipped\",\"delivered\"] },\n\n    \"searchValue\":    { \"type\": \"string\", \"default\": \"shipped\" },\n    \"orderId\":        { \"type\": \"string\", \"default\": \"42\" },\n    \"currencyCode\":   { \"type\": \"string\", \"default\": \"USD\" },\n    \"cardNumber\":     { \"type\": \"string\", \"default\": \"4532015112830366\" },\n    \"emailAddress\":   { \"type\": \"string\", \"default\": \"alice.wonder@acme.com\" },\n    \"regionOverride\": { \"type\": \"string\", \"default\": \"\" },\n    \"regionDefault\":  { \"type\": \"string\", \"default\": \"us-east-1\" },\n    \"invoiceId\":      { \"type\": \"string\", \"default\": \"order-2024-INV-0042\" }\n  }\n}",
                    "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"negativeTemp\":   { \"type\": \"number\",  \"default\": -273.15 },\n    \"positiveNum\":    { \"type\": \"number\",  \"default\": 42.5 },\n    \"powBase\":        { \"type\": \"number\",  \"default\": 2 },\n    \"powExp\":         { \"type\": \"number\",  \"default\": 10 },\n    \"compoundBase\":   { \"type\": \"number\",  \"default\": 1.025 },\n    \"compoundExp\":    { \"type\": \"number\",  \"default\": 4 },\n\n    \"tempReadings\":   { \"type\": \"array\", \"items\": { \"type\": \"number\" },  \"default\": [22.5, 19.8, 25.1, 18.3, 23.7, 21.0] },\n    \"deviceIds\":      { \"type\": \"array\", \"items\": { \"type\": \"string\" },  \"default\": [\"sensor-1\",\"sensor-2\",\"sensor-1\",\"sensor-3\",\"sensor-2\"] },\n    \"orderStatuses\":  { \"type\": \"array\", \"items\": { \"type\": \"string\" },  \"default\": [\"pending\",\"processing\",\"shipped\",\"delivered\"] },\n\n    \"searchValue\":    { \"type\": \"string\", \"default\": \"shipped\" },\n    \"orderId\":        { \"type\": \"string\", \"default\": \"42\" },\n    \"currencyCode\":   { \"type\": \"string\", \"default\": \"USD\" },\n    \"cardNumber\":     { \"type\": \"string\", \"default\": \"4532015112830366\" },\n    \"emailAddress\":   { \"type\": \"string\", \"default\": \"alice.wonder@acme.com\" },\n    \"regionOverride\": { \"type\": \"string\", \"default\": \"\" },\n    \"regionDefault\":  { \"type\": \"string\", \"default\": \"us-east-1\" },\n    \"invoiceId\":      { \"type\": \"string\", \"default\": \"order-2024-INV-0042\" }\n  }\n}"
                  }
                },
                "output": {

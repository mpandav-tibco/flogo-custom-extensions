e\": \"string\",\n      \"default\": \"us-east-1\"\n    },\n    \"invoiceId\": {\n      \"type\": \"string\",\n      \"default\": \"order-2024-INV-0042\"\n    }\n  }\n}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "Mapper1",
            "name": "Mapper1",
            "description": "Mapper Activity",
            "activity": {
              "ref": "#mapper",
              "input": {
                "input": {
                  "mapping": {
                    "absTemp": "=math.abs($activity[Mapper].output.negativeTemp)",
                    "absPos": "=math.abs($activity[Mapper].output.positiveNum)",
                    "powResult": "=math.pow($activity[Mapper].output.powBase,$activity[Mapper].output.powExp)",
                    "compoundResult": "=math.pow($activity[Mapper].output.compoundBase,$activity[Mapper].output.compoundExp)",
                    "minTemp": "=array.min(coerce.toArray($activity[Mapper].output.tempReadings))",
                    "maxTemp": "=array.max(coerce.toArray($activity[Mapper].output.tempReadings))",
                    "avgTemp": "=array.avg(coerce.toArray($activity[Mapper].output.tempReadings))",
                    "uniqueDevices": {
                      "@foreach($activity[Mapper].output.deviceIds,index)": {
                        "=": "$loop"
                      }
                    },
                    "statusIndex": "=array.indexOf(coerce.toArray($activity[Mapper].output.orderStatuses),$activity[Mapper].output.searchValue)",
                    "paddedOrderId": "=string.padLeft($activity[Mapper].output.orderId,8,\"0\")",
                    "paddedCurrency": "=string.padRight($activity[Mapper].output.currencyCode,10,\" \")",
                    "maskedCard": "=string.mask($activity[Mapper].output.cardNumber,0,4)",
                    "maskedEmail": "=string.mask($activity[Mapper].output.emailAddress,2,9)",
                    "resolvedRegion": "=util.coalesce($activity[Mapper].output.regionOverride, $activity[Mapper].output.regionDefault)",
                    "invoiceHash": "=util.sha256($activity[Mapper].output.invoiceId)"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"absTemp\":{\"type\":\"number\"},\"absPos\":{\"type\":\"number\"},\"powResult\":{\"type\":\"number\"},\"compoundResult\":{\"type\":\"number\"},\"minTemp\":{\"type\":\"number\"},\"maxTemp\":{\"type\":\"number\"},\"avgTemp\":{\"type\":\"number\"},\"uniqueDevices\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"statusIndex\":{\"type\":\"number\"},\"paddedOrderId\":{\"type\":\"string\"},\"paddedCurrency\":{\"type\":\"string\"},\"maskedCard\":{\"type\":\"string\"},\"maskedEmail\":{\"type\":\"string\"},\"resolvedRegion\":{\"type\":\"string\"},\"invoiceHash\":{\"type\":\"string\"}}}",
                    "fe_metadata": "{\n  \"absTemp\":        273.15,\n  \"absPos\":         42.5,\n  \"powResult\":      1024,\n  \"compoundResult\": 1.10381289062500,\n  \"minTemp\":        18.3,\n  \"maxTemp\":        25.1,\n  \"avgTemp\":        21.733333333333334,\n  \"uniqueDevices\":  [\"sensor-1\", \"sensor-2\", \"sensor-3\"],\n  \"statusIndex\":    2,\n  \"paddedOrderId\":  \"00000042\",\n  \"paddedCurrency\": \"USD       \",\n  \"maskedCard\":     \"************0366\",\n  \"maskedEmail\":    \"al**********@acme.com\",\n  \"resolvedRegion\": \"us-east-1\",\n  \"invoiceHash\":    \"3b6a198e6f182f279a452a2cf80e14c679680a658f53da4fae81572fac84b579\"\n}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"absTemp\":{\"type\":\"number\"},\"absPos\":{\"type\":\"number\"},\"powResult\":{\"type\":\"number\"},\"compoundResult\":{\"type\":\"number\"},\"minTemp\":{\"type\":\"number\"},\"maxTemp\":{\"type\":\"number\"},\"avgTemp\":{\"type\":\"number\"},\"uniqueDevices\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"statusIndex\":{\"type\":\"number\"},\"paddedOrderId\":{\"type\":\"string\"},\"paddedCurrency\":{\"type\":\"string\"},\"maskedCard\":{\"type\":\"string\"},\"maskedEmail\":{\"type\":\"string\"},\"resolvedRegion\":{\"type\":\"string\"},\"invoiceHash\":{\"type\":\"string\"}}}",
                    "fe_metadata": "{\n  \"absTemp\": 273.15,\n  \"absPos\": 42.5,\n  \"powResult\": 1024,\n  \"compoundResult\": 1.103812890625,\n  \"minTemp\": 18.3,\n  \"maxTemp\": 25.1,\n  \"avgTemp\": 21.733333333333334,\n  \"uniqueDevices\": [\n    \"sensor-1\",\n    \"sensor-2\",\n    \"sensor-3\"\n  ],\n  \"statusIndex\": 2,\n  \"paddedOrderId\": \"00000042\",\n  \"paddedCurrency\": \"USD       \",\n  \"maskedCard\": \"************0366\",\n  \"maskedEmail\": \"al**********@acme.com\",\n  \"resolvedRegion\": \"us-east-1\",\n  \"invoiceHash\": \"3b6a198e6f182f279a452a2cf80e14c679680a658f53da4fae81572fac84b579\"\n}"
                  }

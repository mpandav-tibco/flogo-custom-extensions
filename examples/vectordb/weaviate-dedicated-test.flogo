    {
      "id": "flow:rerank_test",
      "data": {
        "name": "rerank_test",
        "description": "Test rerank activity — calls Cohere rerank API",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "RerankDocs",
            "type": "label",
            "label": "StartActivity to RerankDocs"
          },
          {
            "id": 2,
            "from": "RerankDocs",
            "to": "LogSummary",
            "type": "label",
            "label": "RerankDocs to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "RerankDocs",
            "name": "RerankDocs",
            "description": "",
            "activity": {
              "ref": "#rerank",
              "settings": {
                "rerankEndpoint": "=$property[\"RERANK_ENDPOINT\"]",
                "model": "rerank-english-v3.0",
                "topN": 3,
                "timeoutSeconds": 30
              },
              "input": {
                "query": "Which sentence is about machine learning?",
                "documents": {
                  "mapping": [
                    "The quick brown fox jumps over the lazy dog",
                    "Machine learning enables computers to learn from data automatically",
                    "Vector databases store high-dimensional embeddings"
                  ]
                }
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "=string.concat('Weaviate Rerank - success=', coerce.toString($activity[RerankDocs].success), ' total=', coerce.toString($activity[RerankDocs].totalCount))",
                "logLevel": "INFO"
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJlcmFua0RvY3MiOnsieCI6MjUwLCJ5IjoxNTB9LCJMb2dTdW1tYXJ5Ijp7IngiOjQ1MCwieSI6MjUwfX0=",
        "metadata": {

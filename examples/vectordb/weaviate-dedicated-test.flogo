  "resources": [
    {
      "id": "flow:crud_cycle",
      "data": {
        "name": "crud_cycle",
        "description": "Full CRUD test: createCollection → upsert 3 docs → count → vectorSearch → hybridSearch → getDocument → scrollDocuments → deleteDocuments → count → deleteCollection",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ListBefore",
            "type": "label",
            "label": "StartActivity to ListBefore"
          },
          {
            "id": 2,
            "from": "ListBefore",
            "to": "CreateCollection",
            "type": "label",
            "label": "ListBefore to CreateCollection"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "IngestDocs",
            "type": "label",
            "label": "CreateCollection to UpsertDocs"
          },
          {
            "id": 4,
            "from": "IngestDocs",
            "to": "CountDocs1",
            "type": "label",
            "label": "UpsertDocs to CountDocs1"
          },
          {
            "id": 5,
            "from": "CountDocs1",
            "to": "HybridSearch",
            "type": "default"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ListBefore",
            "name": "ListBefore",
            "description": "",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://weaviate-conn"
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Ingest documents with auto-embedding into the collection",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://weaviate-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 8
              },
              "input": {
                "collectionName": "flogodemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "crud-001",
                      "text": "The quick brown fox jumps over the lazy dog in the park."
                    },
                    {
                      "id": "crud-002",
                      "text": "Machine learning enables computers to learn from data without explicit programming."
                    },
                    {
                      "id": "crud-003",
                      "text": "Vector databases store high-dimensional embeddings and enable fast similarity search."
                    },
                    {
                      "id": "crud-004",
                      "text": "The Flogo framework provides visual programming for IoT and microservices."
                    },
                    {
                      "id": "crud-005",
                      "text": "Artificial intelligence is transforming many industries with automation and insights."
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "CountDocs1",
            "name": "CountDocs1",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "HybridSearch",
            "name": "HybridSearch",
            "description": "",
            "activity": {
              "ref": "#hybridSearch",
              "settings": {
                "connection": "conn://weaviate-conn",
                "defaultTopK": 10
              },
              "input": {
                "collectionName": "flogodemo",
                "queryText": "fox jumps",
                "topK": 3,
                "scoreThreshold": 0,
                "alpha": 0.5,
                "skipPayload": false
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxpc3RCZWZvcmUiOnsieCI6MjUwLCJ5IjoxNTB9LCJDcmVhdGVDb2xsZWN0aW9uIjp7IngiOjQ1MCwieSI6MjUwfSwiSW5nZXN0RG9jcyI6eyJ4Ijo1MDAsInkiOjUwfSwiQ291bnREb2NzMSI6eyJ4Ijo4NTAsInkiOjQ1MH0sIkh5YnJpZFNlYXJjaCI6eyJ4IjoxMjUwLCJ5Ijo2NTB9fQ==",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }
    },
    {
      "id": "flow:rag_cycle",
      "data": {
        "name": "rag_cycle",
        "description": "RAG cycle with hybrid search: createCollection → ingestDocuments → ragQuery → hybridSearch → deleteCollection",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateRAGCol",
            "type": "label",
            "label": "StartActivity to CreateRAGCol"
          },
          {
            "id": 2,
            "from": "CreateRAGCol",
            "to": "IngestDocs",
            "type": "label",
            "label": "CreateRAGCol to IngestDocs"
          },
          {
            "id": 3,
            "from": "IngestDocs",
            "to": "RAGQuery",
            "type": "label",
            "label": "IngestDocs to RAGQuery"
          },
          {
            "id": 4,
            "from": "RAGQuery",
            "to": "HybridRAG",
            "type": "label",
            "label": "RAGQuery to HybridRAG"
          },
          {
            "id": 5,
            "from": "HybridRAG",
            "to": "DeleteRAGCol",
            "type": "label",
            "label": "HybridRAG to DeleteRAGCol"
          },
          {
            "id": 6,
            "from": "DeleteRAGCol",
            "to": "LogSummary",
            "type": "label",
            "label": "DeleteRAGCol to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateRAGCol",
            "name": "CreateRAGCol",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "ragdemo",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://weaviate-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 60,
                "embeddingBatchSize": 8
              },
              "input": {
                "collectionName": "ragdemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "rag-001",
                      "text": "Transformers use self-attention mechanisms to process sequential data in parallel, enabling massive parallelization during training."
                    },
                    {
                      "id": "rag-002",
                      "text": "The attention mechanism allows neural networks to focus on relevant parts of the input when generating output."
                    },
                    {
                      "id": "rag-003",
                      "text": "BERT (Bidirectional Encoder Representations from Transformers) pre-trains deep bidirectional representations using masked language modeling."
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "RAGQuery",
            "name": "RAGQuery",
            "description": "",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://weaviate-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 60,
                "useHybridSearch": false,
                "hybridAlpha": 0.5,
                "enableLLMGenerate": false,
                "llmProvider": "Ollama",
                "llmBaseURL": "http://localhost:11434",
                "llmModel": "llama3.1:8b",
                "systemPrompt": "You are a helpful assistant. Answer the question using only the provided context. If the context does not contain enough information, say so.",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "How does the attention mechanism work in transformer models?",
                "collectionName": "ragdemo",
                "topK": 3
              }
            }
          },
          {
            "id": "HybridRAG",
            "name": "HybridRAG",
            "description": "",
            "activity": {
              "ref": "#hybridSearch",
              "settings": {
                "connection": "conn://weaviate-conn",
                "defaultTopK": 10
              },
              "input": {
                "collectionName": "ragdemo",
                "queryText": "attention mechanism transformers",
                "topK": 3,
                "scoreThreshold": 0,
                "alpha": 0.5,
                "skipPayload": false
              }
            }
          },
          {
            "id": "DeleteRAGCol",
            "name": "DeleteRAGCol",
            "description": "",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "ragdemo"
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "=string.concat('Weaviate RAG COMPLETE - ingested=', coerce.toString($activity[IngestDocs].ingestedCount), ' found=', coerce.toString($activity[RAGQuery].totalFound))",
                "logLevel": "INFO"
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkNyZWF0ZVJBR0NvbCI6eyJ4IjoyNTAsInkiOjE1MH0sIkluZ2VzdERvY3MiOnsieCI6NDUwLCJ5IjoyNTB9LCJSQUdRdWVyeSI6eyJ4Ijo2NTAsInkiOjM1MH0sIkh5YnJpZFJBRyI6eyJ4Ijo4NTAsInkiOjQ1MH0sIkRlbGV0ZVJBR0NvbCI6eyJ4IjoxMDUwLCJ5Ijo1NTB9LCJMb2dTdW1tYXJ5Ijp7IngiOjEyNTAsInkiOjY1MH19",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }
    },
    {
      "id": "flow:embed_test",
      "data": {
        "name": "embed_test",
        "description": "Test createEmbeddings activity with Ollama provider",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "EmbedSingle",
            "type": "label",
            "label": "StartActivity to EmbedSingle"
          },
          {
            "id": 2,
            "from": "EmbedSingle",
            "to": "EmbedBatch",
            "type": "label",
            "label": "EmbedSingle to EmbedBatch"
          },
          {
            "id": 3,
            "from": "EmbedBatch",
            "to": "LogSummary",
            "type": "label",
            "label": "EmbedBatch to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "EmbedSingle",
            "name": "EmbedSingle",
            "description": "",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputText": "Flogo vector connector test — single embedding"
              }
            }
          },
          {
            "id": "EmbedBatch",
            "name": "EmbedBatch",
            "description": "",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputTexts": {
                  "mapping": [
                    "The quick brown fox",
                    "Machine learning is powerful",
                    "Vector similarity search"
                  ]
                }
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "=string.concat('Weaviate Embed COMPLETE - single_dims=', coerce.toString($activity[EmbedSingle].dimensions), ' batch_dims=', coerce.toString($activity[EmbedBatch].dimensions))",
                "logLevel": "INFO"
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkVtYmVkU2luZ2xlIjp7IngiOjI1MCwieSI6MTUwfSwiRW1iZWRCYXRjaCI6eyJ4Ijo0NTAsInkiOjI1MH0sIkxvZ1N1bW1hcnkiOnsieCI6NjUwLCJ5IjozNTB9fQ==",

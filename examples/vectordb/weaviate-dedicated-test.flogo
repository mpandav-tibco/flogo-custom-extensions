        "maxRetries": "=$property[\"VectorDB.weaviate-conn.Max_Retries\"]",
        "retryBackoffMs": "=$property[\"VectorDB.weaviate-conn.Retry_Backoff_(ms)\"]",
        "scheme": "http",
        "enableEmbedding": "=$property[\"VectorDB.weaviate-conn.Configure_Embedding_Provider\"]",

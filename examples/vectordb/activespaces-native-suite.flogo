    {
      "id": "flow:rag",
      "data": {
        "name": "rag",
        "description": "Ingest text (embedded via Ollama) then RAG-query the grid",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateRagColl",
            "type": "label",
            "label": "StartActivity to CreateRagColl"

  "connections": {
    "as-native": {
      "id": "as-native",
      "name": "as-native",
      "ref": "#connector",
      "isGlobal": false,
      "settings": {
        "name": "=$property[\"ActiveSpaces Native.as-native.Connection_Name\"]",
        "host": "=$property[\"ActiveSpaces Native.as-native.Realm_Server_Host\"]",
        "port": "=$property[\"ActiveSpaces Native.as-native.Realm_Server_Port\"]",
        "apiKey": "=$property[\"ActiveSpaces Native.as-native.API_Key\"]",
        "useTLS": "=$property[\"ActiveSpaces Native.as-native.Secure_Connection\"]",
        "tlsInsecureSkipVerify": false,
        "tlsServerName": "",
        "caCert": "",
        "clientCert": "",
        "clientKey": "",
        "timeoutSeconds": "=$property[\"ActiveSpaces Native.as-native.Timeout_(seconds)\"]",
        "maxRetries": "=$property[\"ActiveSpaces Native.as-native.Max_Retries\"]",
        "retryBackoffMs": "=$property[\"ActiveSpaces Native.as-native.Retry_Backoff_(ms)\"]",
        "gridName": "=$property[\"ActiveSpaces Native.as-native.Grid_Name\"]",
        "enableEmbedding": "=$property[\"ActiveSpaces Native.as-native.Configure_Embedding_Provider\"]",
        "embeddingProvider": "OpenAI",
        "embeddingAPIKey": "",
        "embeddingBaseURL": ""
      }
    }
  },

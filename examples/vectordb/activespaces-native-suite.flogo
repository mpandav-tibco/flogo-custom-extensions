        "title": "SuiteTrigger",
        "swagger": {
          "swagger": "2.0",
          "info": {
            "title": "activespaces-native-suite",
            "version": "1.0.0",
            "description": "REST trigger exposing one endpoint per activity group"
          },
          "paths": {
            "/api/native/crud": {
              "post": {
                "summary": "crud",
                "operationId": "post_api_native_crud",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "type": "string"
                    }
                  }
                },
                "description": "Exercises collection + document + search activities on the live grid",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/api/native/embed": {
              "post": {
                "summary": "embed",
                "operationId": "post_api_native_embed",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "type": "string"
                    }
                  }
                },
                "description": "Generate an embedding via Ollama",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/api/native/rag": {
              "post": {
                "summary": "rag",
                "operationId": "post_api_native_rag",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "type": "string"
                    }
                  }
                },
                "description": "Ingest text (embedded via Ollama) then RAG-query the grid",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/api/native/rerank": {
              "post": {

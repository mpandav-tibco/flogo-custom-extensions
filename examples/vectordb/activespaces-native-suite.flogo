          },
          {
            "id": "CreateRagColl",
            "name": "CreateRagColl",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite_rag",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "Ingest",
            "name": "Ingest",
            "description": "",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://as-native",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "Ollama",
                "embeddingBaseURL": "http://host.docker.internal:11434",
                "embeddingModel": "nomic-embed-text",
                "embeddingDimensions": 768,
                "contentField": "text",
                "timeoutSeconds": 60,
                "embeddingBatchSize": 100
              },
              "input": {
                "collectionName": "native_suite_rag",
                "documents": {
                  "mapping": [
                    {
                      "id": "a1",
                      "text": "Cheetahs are the fastest land animals, reaching 120 km/h.",
                      "metadata": {
                        "topic": "animals"
                      }
                    },
                    {
                      "id": "a2",
                      "text": "The Go programming language compiles to fast native machine code.",
                      "metadata": {
                        "topic": "tech"
                      }
                    },
                    {
                      "id": "a3",
                      "text": "Peregrine falcons dive at over 300 km/h, the fastest of any animal.",
                      "metadata": {
                        "topic": "animals"
                      }
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "Rag",
            "name": "Rag",
            "description": "",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://as-native",
                "useConnectorEmbedding": false,
                "embeddingProvider": "Ollama",
                "embeddingBaseURL": "http://host.docker.internal:11434",
                "embeddingModel": "nomic-embed-text",
                "embeddingDimensions": 768,
                "defaultTopK": 5,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 30,
                "useHybridSearch": false,
                "hybridAlpha": 0.5,
                "enableLLMGenerate": false,
                "llmProvider": "Ollama",
                "llmBaseURL": "http://localhost:11434",
                "llmModel": "llama3.1:8b",
                "systemPrompt": "You are a helpful assistant. Answer the question using only the provided context. If the context does not contain enough information, say so.",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "Which animal is the fastest?",
                "collectionName": "native_suite_rag",
                "topK": 3
              }
            }
          },
          {
            "id": "DelRagColl",
            "name": "DelRagColl",
            "description": "",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite_rag"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "test": "rag",
                      "ingested": "=$activity[Ingest].ingestedCount",
                      "ingest_dimensions": "=$activity[Ingest].dimensions",
                      "rag_total_found": "=$activity[Rag].totalFound",
                      "rag_formatted_context": "=$activity[Rag].formattedContext",
                      "rag_source_documents": "=$activity[Rag].sourceDocuments",
                      "ingest_error": "=$activity[Ingest].error",
                      "rag_error": "=$activity[Rag].error"
                    }
                  }
                }
              }
            }
          }
        ],

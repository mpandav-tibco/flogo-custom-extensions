            "from": "Ingest",
            "to": "Rag",
            "type": "label",
            "label": "Ingest to Rag"
          },
          {
            "id": 4,
            "from": "Rag",
            "to": "DelRagColl",
            "type": "label",
            "label": "Rag to DelRagColl"
          },
          {
            "id": 5,
            "from": "DelRagColl",
            "to": "Return",
            "type": "label",
            "label": "DelRagColl to Return"
          }

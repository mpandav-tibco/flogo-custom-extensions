{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/createCollection",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/listCollections",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/upsertDocuments",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/countDocuments",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/getDocument",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/scrollDocuments",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/vectorSearch",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/hybridSearch",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/deleteDocuments",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/deleteCollection",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/createEmbeddings",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/ingestDocuments",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/ragQuery",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/activity/rerank",
    "github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/mpandav-tibco/flogo-extensions/VectorDB/activespaces/nativeAS/connector"
  ],
  "name": "activespaces-native-suite",
  "description": "Comprehensive test suite for the NATIVE ActiveSpaces connector: exercises all 14 activities across 4 REST endpoints against a live grid + Ollama.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "REST trigger exposing one endpoint per activity group",
      "settings": {
        "port": 19090,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "SuiteTrigger",
      "handlers": [
        {
          "description": "Exercises collection + document + search activities on the live grid",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/api/native/crud",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:crud"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "crud"
        },
        {
          "description": "Generate an embedding via Ollama",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/api/native/embed",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:embed"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "embed"
        },
        {
          "description": "Ingest text (embedded via Ollama) then RAG-query the grid",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/api/native/rag",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:rag"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "rag"
        },
        {
          "description": "Rerank documents via a cross-encoder endpoint (set apiKey to use)",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/api/native/rerank",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:rerank"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "rerank"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:crud",
      "data": {
        "name": "crud",
        "description": "Exercises collection + document + search activities on the live grid",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateColl",
            "type": "label",
            "label": "StartActivity to CreateColl"
          },
          {
            "id": 2,
            "from": "CreateColl",
            "to": "ListColls",
            "type": "label",
            "label": "CreateColl to ListColls"
          },
          {
            "id": 3,
            "from": "ListColls",
            "to": "Upsert",
            "type": "label",
            "label": "ListColls to Upsert"
          },
          {
            "id": 4,
            "from": "Upsert",
            "to": "CountAll",
            "type": "label",
            "label": "Upsert to CountAll"
          },
          {
            "id": 5,
            "from": "CountAll",
            "to": "CountAnimals",
            "type": "label",
            "label": "CountAll to CountAnimals"
          },
          {
            "id": 6,
            "from": "CountAnimals",
            "to": "GetDoc",
            "type": "label",
            "label": "CountAnimals to GetDoc"
          },
          {
            "id": 7,
            "from": "GetDoc",
            "to": "Scroll",
            "type": "label",
            "label": "GetDoc to Scroll"
          },
          {
            "id": 8,
            "from": "Scroll",
            "to": "Search",
            "type": "label",
            "label": "Scroll to Search"
          },
          {
            "id": 9,
            "from": "Search",
            "to": "Hybrid",
            "type": "label",
            "label": "Search to Hybrid"
          },
          {
            "id": 10,
            "from": "Hybrid",
            "to": "DelDocs",
            "type": "label",
            "label": "Hybrid to DelDocs"
          },
          {
            "id": 11,
            "from": "DelDocs",
            "to": "CountAfter",
            "type": "label",
            "label": "DelDocs to CountAfter"
          },
          {
            "id": 12,
            "from": "CountAfter",
            "to": "DelColl",
            "type": "label",
            "label": "CountAfter to DelColl"
          },
          {
            "id": 13,
            "from": "DelColl",
            "to": "Return",
            "type": "label",
            "label": "DelColl to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateColl",
            "name": "CreateColl",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "dimensions": 4,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "ListColls",
            "name": "ListColls",
            "description": "",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://as-native"
              }
            }
          },
          {
            "id": "Upsert",
            "name": "Upsert",
            "description": "",
            "activity": {
              "ref": "#upsertDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "documents": {
                  "mapping": [
                    {
                      "id": "doc-1",
                      "content": "The quick brown fox jumps",
                      "vector": [
                        0.1,
                        0.2,
                        0.3,
                        0.4
                      ],
                      "category": "animals"
                    },
                    {
                      "id": "doc-2",
                      "content": "Deep learning neural networks",
                      "vector": [
                        0.9,
                        0.1,
                        0.05,
                        0.1
                      ],
                      "category": "tech"
                    },
                    {
                      "id": "doc-3",
                      "content": "A lazy dog sleeps all day",
                      "vector": [
                        0.15,
                        0.22,
                        0.31,
                        0.38
                      ],
                      "category": "animals"
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "CountAll",
            "name": "CountAll",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite"
              }
            }
          },
          {
            "id": "CountAnimals",
            "name": "CountAnimals",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "filters": {
                  "mapping": {
                    "category": "animals"
                  }
                }
              }
            }
          },
          {
            "id": "GetDoc",
            "name": "GetDoc",
            "description": "",
            "activity": {
              "ref": "#getDocument",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "documentId": "doc-1"
              }
            }
          },
          {
            "id": "Scroll",
            "name": "Scroll",
            "description": "",
            "activity": {
              "ref": "#scrollDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "limit": 10,
                "offset": "",
                "withVectors": false
              }
            }
          },
          {
            "id": "Search",
            "name": "Search",
            "description": "",
            "activity": {
              "ref": "#vectorSearch",
              "settings": {
                "connection": "conn://as-native",
                "defaultTopK": 10
              },
              "input": {
                "collectionName": "native_suite",
                "topK": 3,
                "scoreThreshold": 0,
                "withVectors": false,
                "skipPayload": false,
                "queryVector": {
                  "mapping": [
                    0.1,
                    0.2,
                    0.3,
                    0.4
                  ]
                }
              }
            }
          },
          {
            "id": "Hybrid",
            "name": "Hybrid",
            "description": "",
            "activity": {
              "ref": "#hybridSearch",
              "settings": {
                "connection": "conn://as-native",
                "defaultTopK": 10
              },
              "input": {
                "collectionName": "native_suite",
                "queryText": "fox",
                "topK": 3,
                "scoreThreshold": 0,
                "alpha": 0.5,
                "skipPayload": false,
                "queryVector": {
                  "mapping": [
                    0.1,
                    0.2,
                    0.3,
                    0.4
                  ]
                }
              }
            }
          },
          {
            "id": "DelDocs",
            "name": "DelDocs",
            "description": "",
            "activity": {
              "ref": "#deleteDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite",
                "ids": {
                  "mapping": [
                    "doc-2"
                  ]
                }
              }
            }
          },
          {
            "id": "CountAfter",
            "name": "CountAfter",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite"
              }
            }
          },
          {
            "id": "DelColl",
            "name": "DelColl",
            "description": "",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://as-native"
              },
              "input": {
                "collectionName": "native_suite"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "test": "crud",
                      "collection": "native_suite",
                      "list_total": "=$activity[ListColls].totalCount",
                      "upserted": "=$activity[Upsert].upsertedCount",
                      "count_all": "=$activity[CountAll].count",
                      "count_animals": "=$activity[CountAnimals].count",
                      "get_found": "=$activity[GetDoc].found",
                      "get_document": "=$activity[GetDoc].document",
                      "scroll_next_offset": "=$activity[Scroll].nextOffset",
                      "scroll_documents": "=$activity[Scroll].documents",
                      "search_total": "=$activity[Search].totalCount",
                      "search_results": "=$activity[Search].results",
                      "hybrid_total": "=$activity[Hybrid].totalCount",
                      "hybrid_results": "=$activity[Hybrid].results",
                      "deleted": "=$activity[DelDocs].deletedCount",
                      "count_after_delete": "=$activity[CountAfter].count"
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "",
        "metadata": {
          "input": [],
          "output": [
            {
              "name": "code",
              "type": "float64"
            },
            {
              "name": "data",
              "type": "object"
            }
          ],
          "fe_metadata": {
            "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"code\":{\"type\":\"number\"},\"data\":{\"type\":\"object\",\"properties\":{}}}}"
          }
        },
        "explicitReply": true
      }
    },
    {
      "id": "flow:embed",
      "data": {
        "name": "embed",
        "description": "Generate an embedding via Ollama",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Embed",
            "type": "label",
            "label": "StartActivity to Embed"
          },
          {
            "id": 2,
            "from": "Embed",
            "to": "Return",
            "type": "label",
            "label": "Embed to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Embed",
            "name": "Embed",
            "description": "",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "connection": "conn://as-native",
                "useConnectorEmbedding": false,
                "provider": "Ollama",
                "baseURL": "http://host.docker.internal:11434",
                "model": "nomic-embed-text",
                "dimensions": 768,
                "timeoutSeconds": 30
              },
              "input": {
                "inputText": "The quick brown fox jumps over the lazy dog"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "test": "embed",
                      "success": "=$activity[Embed].success",

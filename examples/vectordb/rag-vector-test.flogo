            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "CreateCollection",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "IngestDocs",
            "type": "label",
            "label": "created"
          },
          {
            "id": 4,
            "from": "IngestDocs",
            "to": "LogResult",
            "type": "label",
            "label": "ingested"
          },
          {
            "id": 5,
            "from": "LogResult",
            "to": "Return",

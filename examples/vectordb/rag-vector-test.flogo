    {
      "id": "flow:milvus_query",
      "data": {
        "name": "milvus_query",
        "description": "Accept natural language query, embed with Ollama, retrieve top-K context passages from Milvus",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "RAGQuery",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "RAGQuery",
            "to": "LogResult",
            "type": "label",
            "label": "retrieved"
          },
          {
            "id": 4,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "done"
          }
        ],
        "tasks": [
          {
            "id": "Start",
            "name": "Start",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogRequest",
            "name": "LogRequest",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[milvus] Query request: collection=', coerce.toString($flow.body.collection), ' query=', coerce.toString($flow.body.query))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "RAGQuery",
            "name": "RAGQuery",
            "description": "Embed query text and retrieve top-K semantically similar passages from Milvus",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://milvus-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 60,
                "useHybridSearch": false,
                "hybridAlpha": 0.5,
                "enableLLMGenerate": false,
                "llmProvider": "Ollama",
                "llmBaseURL": "http://localhost:11434",
                "llmModel": "llama3.1:8b",
                "systemPrompt": "You are a helpful assistant. Answer the question using only the provided context. If the context does not contain enough information, say so.",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "=$flow.body.query",
                "collectionName": "=$flow.body.collection",
                "topK": "=$flow.body.topK"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[milvus] Query COMPLETE collection=', coerce.toString($flow.body.collection), ' totalFound=', coerce.toString($activity[RAGQuery].totalFound), ' duration=', $activity[RAGQuery].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[RAGQuery]"
                }
              }
            }
          }
        ],

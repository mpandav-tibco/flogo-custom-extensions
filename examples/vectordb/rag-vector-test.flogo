    {
      "id": "flow:milvus_query",
      "data": {
        "name": "milvus_query",
        "description": "Accept natural language query, embed with Ollama, retrieve top-K context passages from Milvus",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "RAGQuery",
            "type": "label",
            "label": "log"
          },
          {

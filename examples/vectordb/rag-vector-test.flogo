  ],
  "resources": [
    {
      "id": "flow:qdrant_ingest",
      "data": {
        "name": "qdrant_ingest",
        "description": "Accept documents via POST body, embed with Ollama nomic-embed-text, create collection and ingest into Qdrant",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "CreateCollection",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "IngestDocs",
            "type": "label",
            "label": "created"
          },
          {
            "id": 4,
            "from": "IngestDocs",
            "to": "LogResult",
            "type": "label",
            "label": "ingested"
          },
          {
            "id": 5,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "done"
          }
        ],
        "tasks": [
          {
            "id": "Start",
            "name": "Start",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogRequest",
            "name": "LogRequest",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[qdrant] Ingest request: collection=', coerce.toString($flow.body.collection), ' docCount=', coerce.toString($flow.body.documents))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create RAG collection in Qdrant (768-dim cosine)",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Embed documents with Ollama and upsert into Qdrant",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://qdrant-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 10
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "documents": "=$flow.body.documents"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[qdrant] Ingest COMPLETE collection=', coerce.toString($flow.body.collection), ' ingested=', coerce.toString($activity[IngestDocs].ingestedCount), ' dims=', coerce.toString($activity[IngestDocs].dimensions), ' duration=', $activity[IngestDocs].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return ingest result to caller",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[IngestDocs]"
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydCI6eyJ4Ijo1MCwieSI6NTB9LCJMb2dSZXF1ZXN0Ijp7IngiOjI1MCwieSI6MTUwfSwiQ3JlYXRlQ29sbGVjdGlvbiI6eyJ4Ijo0NTAsInkiOjI1MH0sIkluZ2VzdERvY3MiOnsieCI6NjUwLCJ5IjozNTB9LCJMb2dSZXN1bHQiOnsieCI6ODUwLCJ5Ijo0NTB9LCJSZXR1cm4iOnsieCI6MTA1MCwieSI6NTUwfX0=",
        "metadata": {
          "input": [
            {
              "name": "body",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"collection\":{\"type\":\"string\"},\"documents\":{\"type\":\"array\",\"items\":{}}}"
              }
            },
            {
              "name": "headers",
              "type": "object"
            }
          ],
          "output": [
            {
              "name": "code",
              "type": "float64"
            },
            {
              "name": "data",
              "type": "object"
            }
          ],
          "fe_metadata": {
            "input": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"string\"},\"documents\":{\"type\":\"array\",\"items\":{}}}},\"headers\":{\"type\":\"object\",\"properties\":{}}}}",
            "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"code\":{\"type\":\"number\"},\"data\":{\"type\":\"object\",\"properties\":{}}}}"
          }
        },
        "explicitReply": true
      }
    },
    {
      "id": "flow:qdrant_query",
      "data": {
        "name": "qdrant_query",
        "description": "Accept natural language query, embed with Ollama, retrieve top-K context passages from Qdrant",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "RAGQuery",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "RAGQuery",
            "to": "LogResult",
            "type": "label",
            "label": "retrieved"
          },
          {
            "id": 4,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "done"
          }
        ],
        "tasks": [
          {
            "id": "Start",
            "name": "Start",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogRequest",
            "name": "LogRequest",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[qdrant] Query request: collection=', coerce.toString($flow.body.collection), ' query=', coerce.toString($flow.body.query))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "RAGQuery",
            "name": "RAGQuery",
            "description": "Embed query text and retrieve top-K semantically similar passages from Qdrant",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://qdrant-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 60,
                "useHybridSearch": false,
                "hybridAlpha": 0.5,
                "enableLLMGenerate": false,
                "llmProvider": "Ollama",
                "llmBaseURL": "http://localhost:11434",
                "llmModel": "llama3.1:8b",
                "systemPrompt": "You are a helpful assistant. Answer the question using only the provided context. If the context does not contain enough information, say so.",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "=$flow.body.query",
                "collectionName": "=$flow.body.collection",
                "topK": "=$flow.body.topK"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[qdrant] Query COMPLETE collection=', coerce.toString($flow.body.collection), ' totalFound=', coerce.toString($activity[RAGQuery].totalFound), ' duration=', $activity[RAGQuery].duration)",

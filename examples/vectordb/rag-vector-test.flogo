                "message": "=string.concat('[milvus] Ingest request: collection=', coerce.toString($flow.body.collection), ' docCount=', coerce.toString($flow.body.documents))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create RAG collection in Milvus (768-dim cosine)",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://milvus-conn"
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Embed documents with Ollama and upsert into Milvus",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://milvus-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 10
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "documents": "=$flow.body.documents"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[milvus] Ingest COMPLETE collection=', coerce.toString($flow.body.collection), ' ingested=', coerce.toString($activity[IngestDocs].ingestedCount), ' dims=', coerce.toString($activity[IngestDocs].dimensions), ' duration=', $activity[IngestDocs].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[IngestDocs]"
                }
              }
            }
          }
        ],

      "data": {
        "name": "embed_test",
        "description": "Test createEmbeddings activity with Ollama provider - generates embeddings for sample texts (OpenSearch)",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "EmbedSingle",
            "type": "label",
            "label": "StartActivity to EmbedSingle"
          },
          {
            "id": 2,
            "from": "EmbedSingle",
            "to": "EmbedBatch",
            "type": "label",
            "label": "EmbedSingle to EmbedBatch"
          },
          {
            "id": 3,
            "from": "EmbedBatch",
            "to": "LogSummary",
            "type": "label",
            "label": "EmbedBatch to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "EmbedSingle",
            "name": "EmbedSingle",
            "description": "Generate dense vector embeddings",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "connection": "conn://os-conn",
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputText": "Flogo OpenSearch vector connector test - single embedding"
              }
            }
          },
          {
            "id": "EmbedBatch",
            "name": "EmbedBatch",
            "description": "Generate dense vector embeddings batch",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "connection": "conn://os-conn",
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputTexts": {
                  "mapping": [
                    "The quick brown fox",
                    "Machine learning is powerful",
                    "Vector similarity search"
                  ]
                }
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "=string.concat('OpenSearch Embed COMPLETE - single_dims=', coerce.toString($activity[EmbedSingle].dimensions), ' batch_dims=', coerce.toString($activity[EmbedBatch].dimensions))",
                "logLevel": "INFO"
              }
            }
          }
        ],

{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/listCollections",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/createCollection",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/ingestDocuments",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/countDocuments",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/getDocument",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/scrollDocuments",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/deleteDocuments",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/deleteCollection",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/ragQuery",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/createEmbeddings",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/activity/rerank",
    "github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string",
    "github.com/mpandav-tibco/flogo-extensions/vectordb-opensearch/connector"
  ],
  "name": "opensearch-dedicated-test",
  "description": "Live connector test app for OpenSearch 2.x using dedicated vectordb-opensearch connector - CRUD cycle, RAG ingest/query, embeddings, rerank",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "REST trigger for OpenSearch dedicated connector live tests (port 19086)",
      "settings": {
        "port": 19086,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "TestTrigger",
      "handlers": [
        {
          "description": "Full CRUD test: createCollection to ingestDocs to count to getDocument to scrollDocuments to deleteDocuments to count to deleteCollection",
          "settings": {
            "APISpecPath": "",
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/api/test/crud",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:crud_cycle"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "crud_cycle"
        },
        {
          "description": "RAG cycle: createCollection to ingestDocuments (with Ollama embeddings) to ragQuery to deleteCollection",
          "settings": {
            "APISpecPath": "",
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/api/test/rag",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:rag_cycle"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "rag_cycle"
        },
        {
          "description": "Test createEmbeddings activity with Ollama provider - generates embeddings for sample texts",
          "settings": {
            "APISpecPath": "",
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/api/test/embed",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:embed_test"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "embed_test"
        },
        {
          "description": "Test rerank activity - calls Cohere rerank API to reorder documents by relevance",
          "settings": {
            "APISpecPath": "",
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/api/test/rerank",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:rerank_test"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "rerank_test"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:crud_cycle",
      "data": {
        "name": "crud_cycle",
        "description": "Full CRUD test: createCollection to ingestDocs to count to getDocument to scrollDocuments to deleteDocuments to count to deleteCollection (OpenSearch)",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ListBefore",
            "type": "label",
            "label": "StartActivity to ListBefore"
          },
          {
            "id": 2,
            "from": "ListBefore",
            "to": "CreateCollection",
            "type": "label",
            "label": "ListBefore to CreateCollection"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "IngestDocs",
            "type": "label",
            "label": "CreateCollection to IngestDocs"
          },
          {
            "id": 4,
            "from": "IngestDocs",
            "to": "CountDocs1",
            "type": "label",
            "label": "IngestDocs to CountDocs1"
          },
          {
            "id": 5,
            "from": "CountDocs1",
            "to": "GetDoc",
            "type": "label",
            "label": "CountDocs1 to GetDoc"
          },
          {
            "id": 6,
            "from": "GetDoc",
            "to": "ScrollDocs",
            "type": "label",
            "label": "GetDoc to ScrollDocs"
          },
          {
            "id": 7,
            "from": "ScrollDocs",
            "to": "DeleteDocs",
            "type": "label",
            "label": "ScrollDocs to DeleteDocs"
          },
          {
            "id": 8,
            "from": "DeleteDocs",
            "to": "CountDocs2",
            "type": "label",
            "label": "DeleteDocs to CountDocs2"
          },
          {
            "id": 9,
            "from": "CountDocs2",
            "to": "DeleteCollection",
            "type": "label",
            "label": "CountDocs2 to DeleteCollection"
          },
          {
            "id": 10,
            "from": "DeleteCollection",
            "to": "ListAfter",
            "type": "label",
            "label": "DeleteCollection to ListAfter"
          },
          {
            "id": 11,
            "from": "ListAfter",
            "to": "LogSummary",
            "type": "label",
            "label": "ListAfter to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ListBefore",
            "name": "ListBefore",
            "description": "",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://os-conn"
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "dimensions": 768,
                "distanceMetric": "cosine"
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Ingest documents with auto-embedding",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://os-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 8
              },
              "input": {
                "collectionName": "flogodemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "crud-001",
                      "text": "The quick brown fox jumps over the lazy dog in the park."
                    },
                    {
                      "id": "crud-002",
                      "text": "Machine learning enables computers to learn from data without explicit programming."
                    },
                    {
                      "id": "crud-003",
                      "text": "Vector databases store high-dimensional embeddings and enable fast similarity search."
                    },
                    {
                      "id": "crud-004",
                      "text": "The Flogo framework provides visual programming for IoT and microservices."
                    },
                    {
                      "id": "crud-005",
                      "text": "Artificial intelligence is transforming many industries with automation and insights."
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "CountDocs1",
            "name": "CountDocs1",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "GetDoc",
            "name": "GetDoc",
            "description": "",
            "activity": {
              "ref": "#getDocument",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "documentId": "crud-001"
              }
            }
          },
          {
            "id": "ScrollDocs",
            "name": "ScrollDocs",
            "description": "",
            "activity": {
              "ref": "#scrollDocuments",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "limit": 10,
                "offset": "",
                "withVectors": false
              }
            }
          },
          {
            "id": "DeleteDocs",
            "name": "DeleteDocs",
            "description": "",
            "activity": {
              "ref": "#deleteDocuments",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "ids": {
                  "mapping": [
                    "crud-003",
                    "crud-004"
                  ]
                }
              }
            }
          },
          {
            "id": "CountDocs2",
            "name": "CountDocs2",
            "description": "",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "DeleteCollection",
            "name": "DeleteCollection",
            "description": "",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "ListAfter",
            "name": "ListAfter",
            "description": "",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://os-conn"
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "=string.concat('OpenSearch CRUD COMPLETE - count_before=', coerce.toString($activity[CountDocs1].count), ' count_after_delete=', coerce.toString($activity[CountDocs2].count))",
                "logLevel": "INFO"
              }
            }
          }
        ],
        "fe_metadata": "",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }
    },
    {
      "id": "flow:rag_cycle",
      "data": {
        "name": "rag_cycle",
        "description": "RAG cycle: createCollection to ingestDocuments (Ollama embeddings) to ragQuery to deleteCollection (OpenSearch)",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateRAGCol",
            "type": "label",
            "label": "StartActivity to CreateRAGCol"
          },
          {
            "id": 2,
            "from": "CreateRAGCol",
            "to": "IngestDocs",
            "type": "label",
            "label": "CreateRAGCol to IngestDocs"
          },
          {
            "id": 3,
            "from": "IngestDocs",
            "to": "RAGQuery",
            "type": "label",
            "label": "IngestDocs to RAGQuery"
          },
          {
            "id": 4,
            "from": "RAGQuery",
            "to": "DeleteRAGCol",
            "type": "label",
            "label": "RAGQuery to DeleteRAGCol"
          },
          {
            "id": 5,
            "from": "DeleteRAGCol",
            "to": "LogSummary",
            "type": "label",
            "label": "DeleteRAGCol to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateRAGCol",
            "name": "CreateRAGCol",
            "description": "",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://os-conn"
              },
              "input": {
                "collectionName": "ragdemo",
                "dimensions": 768,
                "distanceMetric": "cosine"
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://os-conn",
                "enableChunking": false,
                "chunkStrategy": "paragraph",
                "chunkSize": 1000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 60,
                "embeddingBatchSize": 8
              },
              "input": {
                "collectionName": "ragdemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "rag-001",
                      "text": "Transformers use self-attention mechanisms to process sequential data in parallel, enabling massive parallelization during training."
                    },
                    {
                      "id": "rag-002",
                      "text": "The attention mechanism allows neural networks to focus on relevant parts of the input when generating output."
                    },
                    {
                      "id": "rag-003",
                      "text": "BERT (Bidirectional Encoder Representations from Transformers) pre-trains deep bidirectional representations using masked language modeling."
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "RAGQuery",
            "name": "RAGQuery",
            "description": "",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://os-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 60,
                "useHybridSearch": false,
                "hybridAlpha": 0.5,
                "enableLLMGenerate": false,
                "llmProvider": "Ollama",
                "llmBaseURL": "http://localhost:11434",
                "llmModel": "llama3.1:8b",
                "systemPrompt": "You are a helpful assistant. Answer the question using only the provided context. If the context does not contain enough information, say so.",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "How does the attention mechanism work in transformer models?",
                "collectionName": "ragdemo",
                "topK": 3
              }

      "type": "string",
      "value": "localhost"
    },
    {
      "name": "VectorDB.=$property[\"VectorDB_WeaviateConn_Connection_Name\"].Port",
      "type": "float64",
      "value": 18080
    },
    {
      "name": "VectorDB.=$property[\"VectorDB_WeaviateConn_Connection_Name\"].API_Key",
      "type": "string",
      "value": ""
    },
    {
      "name": "VectorDB.=$property[\"VectorDB_WeaviateConn_Connection_Name\"].Secure_Connection",
      "type": "boolean",
      "value": false
    },
    {
      "name": "VectorDB.=$property[\"VectorDB_WeaviateConn_Connection_Name\"].Timeout_(seconds)",

            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateEmbedding1",
            "name": "CreateEmbedding1",
            "description": "Embed single text, inspect dimensions and token usage",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputText": "Transformers use self-attention mechanisms to process sequential data in parallel."
              }
            }
          },
          {
            "id": "CreateEmbeddings2",
            "name": "CreateEmbeddings2",
            "description": "Batch embed 3 texts; verify all embeddings returned",
            "activity": {
              "ref": "#createEmbeddings",
              "settings": {
                "useConnectorEmbedding": true,
                "provider": "=$property[\"EMBED_PROVIDER\"]",
                "apiKey": "=$property[\"EMBED_API_KEY\"]",
                "baseURL": "=$property[\"EMBED_BASE_URL\"]",
                "model": "=$property[\"EMBED_MODEL\"]",
                "dimensions": 0,
                "timeoutSeconds": 30
              },
              "input": {
                "inputTexts": {
                  "mapping": [
                    "What is retrieval-augmented generation?",
                    "How does HNSW indexing work in vector databases?",
                    "Explain cosine similarity for semantic search."
                  ]
                }
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('Embeddings Test COMPLETE - dims=', coerce.toString($activity[CreateEmbedding1].dimensions), ' single-tokens=', coerce.toString($activity[CreateEmbedding1].tokensUsed), ' batch-dims=', coerce.toString($activity[CreateEmbeddings2].dimensions), ' batch-count=3')",
                "logLevel": ""
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkNyZWF0ZUVtYmVkZGluZzEiOnsieCI6MjUwLCJ5IjoxNTB9LCJDcmVhdGVFbWJlZGRpbmdzMiI6eyJ4Ijo0NTAsInkiOjI1MH0sIkxvZ1N1bW1hcnkiOnsieCI6NjUwLCJ5IjozNTB9fQ==",

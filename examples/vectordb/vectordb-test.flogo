  "resources": [
    {
      "id": "flow:qdrant_test",
      "data": {
        "name": "qdrant_test",
        "description": "VectorDB integration test for qdrant",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ListBefore",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "ListBefore",
            "to": "CreateCollection",
            "type": "label",
            "label": "listed"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "UpsertDocs",
            "type": "label",
            "label": "created"
          },
          {
            "id": 4,
            "from": "UpsertDocs",
            "to": "CountDocs1",
            "type": "label",
            "label": "upserted"
          },
          {
            "id": 5,
            "from": "CountDocs1",
            "to": "SearchVec",
            "type": "label",
            "label": "counted"
          },
          {
            "id": 6,
            "from": "SearchVec",
            "to": "GetDoc",
            "type": "label",
            "label": "searched"
          },
          {
            "id": 7,
            "from": "GetDoc",
            "to": "ScrollDocs",
            "type": "label",
            "label": "got"
          },
          {
            "id": 8,
            "from": "ScrollDocs",
            "to": "DeleteDocs",
            "type": "label",
            "label": "scrolled"
          },
          {
            "id": 9,
            "from": "DeleteDocs",
            "to": "CountDocs2",
            "type": "label",
            "label": "deleted"
          },
          {
            "id": 10,
            "from": "CountDocs2",
            "to": "DeleteCollection",
            "type": "label",
            "label": "counted2"
          },
          {
            "id": 11,
            "from": "DeleteCollection",
            "to": "ListAfter",
            "type": "label",
            "label": "dropcol"
          },
          {
            "id": 12,
            "from": "ListAfter",
            "to": "LogSummary",
            "type": "label",
            "label": "listed2"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "Flow start",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ListBefore",
            "name": "ListBefore",
            "description": "List collections before test",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://qdrant-conn"
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create collection flogodemo (8 dims, cosine)",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "dimensions": 8,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "UpsertDocs",
            "name": "UpsertDocs",
            "description": "Upsert 3 documents with 8-dim vectors",
            "activity": {
              "ref": "#upsertDocuments",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "documents": {
                  "mapping": [
                    {
                      "category": "language",
                      "content": "The quick brown fox jumps over the lazy dog",
                      "id": "doc-001",
                      "vector": [
                        1,
                        0,
                        0,
                        0,
                        0,
                        0,
                        0,
                        0
                      ]
                    },
                    {
                      "category": "tech",
                      "content": "Machine learning enables computers to learn from data",
                      "id": "doc-002",
                      "vector": [
                        0,
                        1,
                        0,
                        0,
                        0,
                        0,
                        0,
                        0
                      ]
                    },
                    {
                      "category": "database",
                      "content": "Vector databases enable efficient similarity search",
                      "id": "doc-003",
                      "vector": [
                        0,
                        0,
                        1,
                        0,
                        0,
                        0,
                        0,
                        0
                      ]
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "CountDocs1",
            "name": "CountDocs1",
            "description": "Count documents - expect 3",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "SearchVec",
            "name": "SearchVec",
            "description": "Vector search [1,0,...,0] topK=3",
            "activity": {
              "ref": "#vectorSearch",
              "settings": {
                "connection": "conn://qdrant-conn",
                "defaultTopK": 10
              },
              "input": {
                "collectionName": "flogodemo",
                "topK": 3,
                "scoreThreshold": 0,
                "withVectors": false,
                "queryVector": {
                  "mapping": [
                    1,
                    0,
                    0,
                    0,
                    0,
                    0,
                    0,
                    0
                  ]
                }
              }
            }
          },
          {
            "id": "GetDoc",
            "name": "GetDoc",
            "description": "Get document doc-001 by ID",
            "activity": {
              "ref": "#getDocument",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "documentId": "doc-001"
              }
            }
          },
          {
            "id": "ScrollDocs",
            "name": "ScrollDocs",
            "description": "Scroll all documents in collection",
            "activity": {
              "ref": "#scrollDocuments",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "limit": 10,
                "offset": "",
                "withVectors": false
              }
            }
          },
          {
            "id": "DeleteDocs",
            "name": "DeleteDocs",
            "description": "Delete doc-003 by ID",
            "activity": {
              "ref": "#deleteDocuments",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo",
                "ids": {
                  "mapping": [
                    "doc-003"
                  ]
                }
              }
            }
          },
          {
            "id": "CountDocs2",
            "name": "CountDocs2",
            "description": "Count documents after delete - expect 2",
            "activity": {
              "ref": "#countDocuments",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "DeleteCollection",
            "name": "DeleteCollection",
            "description": "Delete the test collection",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "flogodemo"
              }
            }
          },
          {
            "id": "ListAfter",
            "name": "ListAfter",
            "description": "List collections after cleanup",
            "activity": {
              "ref": "#listCollections",
              "settings": {
                "connection": "conn://qdrant-conn"
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "Log test completion",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": true,
                "message": "qdrant VectorDB Test Complete (collection=flogodemo) - COMPLETE",
                "logLevel": "INFO"
              }
            }
          }
        ],
        "fe_metadata": "",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }
    },

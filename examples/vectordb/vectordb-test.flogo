    {
      "id": "flow:rerank_test",
      "data": {
        "name": "rerank_test",
        "description": "Test rerank activity — set RERANK_API_KEY for a Cohere-compatible endpoint",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "RerankDocs",
            "type": "label",
            "label": "StartActivity to RerankDocs"
          },
          {
            "id": 2,
            "from": "RerankDocs",
            "to": "LogSummary",
            "type": "label",
            "label": "RerankDocs to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "RerankDocs",
            "name": "RerankDocs",
            "description": "Rerank 5 candidate passages for relevance to query",
            "activity": {
              "ref": "#rerank",
              "settings": {
                "rerankEndpoint": "=$property[\"RERANK_ENDPOINT\"]",
                "apiKey": "=$property[\"RERANK_API_KEY\"]",
                "model": "=$property[\"RERANK_MODEL\"]",
                "topN": 3,
                "timeoutSeconds": 30
              },
              "input": {
                "query": "How does transformer self-attention work?",
                "documents": {
                  "mapping": [
                    "The attention mechanism computes scaled dot-product attention over queries, keys and values.",
                    "BERT uses masked language modeling and next-sentence prediction for pre-training.",
                    "Vector databases enable fast approximate nearest neighbor search over embeddings.",
                    "Transformers replaced RNNs by processing all tokens in parallel using self-attention.",
                    "Cosine similarity is used to compare query embeddings with document embeddings."
                  ]
                }
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('Rerank Test COMPLETE - totalReranked=', coerce.toString($activity[RerankDocs].totalCount))",
                "logLevel": ""
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJlcmFua0RvY3MiOnsieCI6MjUwLCJ5IjoxNTB9LCJMb2dTdW1tYXJ5Ijp7IngiOjQ1MCwieSI6MjUwfX0=",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }
    }

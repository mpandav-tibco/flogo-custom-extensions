    {
      "id": "flow:qdrant_rag_test",
      "data": {
        "name": "qdrant_rag_test",
        "description": "RAG test: embed 8 docs, ragQuery",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateRAGCol",
            "type": "label",
            "label": "StartActivity to CreateRAGCol"
          },
          {
            "id": 2,
            "from": "CreateRAGCol",
            "to": "IngestDocs",
            "type": "label",
            "label": "CreateRAGCol to IngestDocs"
          },
          {
            "id": 3,
            "from": "IngestDocs",
            "to": "RAGQuery",
            "type": "label",
            "label": "IngestDocs to RAGQuery"
          },
          {
            "id": 4,
            "from": "RAGQuery",
            "to": "DeleteRAGCol",
            "type": "label",
            "label": "RAGQuery to DeleteRAGCol"
          },
          {
            "id": 5,
            "from": "DeleteRAGCol",
            "to": "LogSummary",
            "type": "label",
            "label": "DeleteRAGCol to LogSummary"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateRAGCol",
            "name": "CreateRAGCol",
            "description": "Create ragdemo for RAG (768-dim cosine)",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "ragdemo",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Embed 8 AI/ML passages with nomic-embed-text and upsert",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://qdrant-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "contentField": "text",
                "timeoutSeconds": 60,
                "embeddingBatchSize": 8
              },
              "input": {
                "collectionName": "ragdemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "rag-001",
                      "text": "Transformers use self-attention mechanisms to process sequential data in parallel, enabling massive parallelization during training."
                    },
                    {
                      "id": "rag-002",
                      "text": "BERT is a bidirectional transformer model pre-trained on masked language modeling and next-sentence prediction tasks."
                    },
                    {
                      "id": "rag-003",
                      "text": "Retrieval-Augmented Generation (RAG) grounds language model responses in external knowledge by retrieving relevant documents at inference time."
                    },
                    {
                      "id": "rag-004",
                      "text": "Vector databases index high-dimensional embeddings and use approximate nearest neighbor algorithms like HNSW for fast semantic search."
                    },
                    {
                      "id": "rag-005",
                      "text": "The attention mechanism computes scaled dot-product attention: softmax(QK^T divided by sqrt(d_k)) times V, letting each token attend to all positions."
                    },
                    {
                      "id": "rag-006",
                      "text": "TIBCO Flogo is an open-source ultralight microservices framework that compiles integration flows into single self-contained executable binaries."
                    },
                    {
                      "id": "rag-007",
                      "text": "Cosine similarity measures the angle between two embedding vectors and is the standard distance metric for semantic similarity search."
                    },
                    {
                      "id": "rag-008",
                      "text": "Hybrid search combines dense vector retrieval with sparse BM25 keyword matching, achieving better recall than either approach alone."
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "RAGQuery",
            "name": "RAGQuery",
            "description": "Embed question, retrieve top-3 context passages",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://qdrant-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "numbered",
                "timeoutSeconds": 60,
                "useHybridSearch": false,
                "hybridAlpha": 0.5
              },
              "input": {
                "queryText": "How does the attention mechanism work in transformer models?",
                "collectionName": "ragdemo",
                "topK": 3
              }
            }
          },
          {
            "id": "DeleteRAGCol",
            "name": "DeleteRAGCol",
            "description": "Drop RAG test collection",
            "activity": {
              "ref": "#deleteCollection",
              "settings": {
                "connection": "conn://qdrant-conn"
              },
              "input": {
                "collectionName": "ragdemo"
              }
            }
          },
          {
            "id": "LogSummary",
            "name": "LogSummary",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('qdrant RAG Test COMPLETE - ingested=', coerce.toString($activity[IngestDocs].ingestedCount), ' dims=', coerce.toString($activity[IngestDocs].dimensions), ' ragFound=', coerce.toString($activity[RAGQuery].totalFound))",
                "logLevel": ""
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkNyZWF0ZVJBR0NvbCI6eyJ4IjoyNTAsInkiOjE1MH0sIkluZ2VzdERvY3MiOnsieCI6NDUwLCJ5IjoyNTB9LCJSQUdRdWVyeSI6eyJ4Ijo2NTAsInkiOjM1MH0sIkRlbGV0ZVJBR0NvbCI6eyJ4Ijo4NTAsInkiOjQ1MH0sIkxvZ1N1bW1hcnkiOnsieCI6MTA1MCwieSI6NTUwfX0=",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        },
        "explicitReply": true
      }

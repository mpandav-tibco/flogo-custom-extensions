  "name": "vdb-test",
  "description": "VectorDB integration test - Qdrant, Weaviate, Chroma, Milvus",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "REST trigger on port 8888",
      "settings": {
        "port": 8888,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "VectorDBTestTrigger",
      "handlers": [
        {
          "description": "VectorDB integration test for qdrant",
          "settings": {
            "APISpecPath": "",
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/test/qdrant",
            "OutputValidation": false

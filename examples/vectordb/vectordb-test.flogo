              },
              "input": {
                "collectionName": "Ragdemo",
                "documents": {
                  "mapping": [
                    {
                      "id": "rag-001",
                      "text": "Transformers use self-attention mechanisms to process sequential data in parallel, enabling massive parallelization during training."
                    },
                    {
                      "id": "rag-002",
                      "text": "BERT is a bidirectional transformer model pre-trained on masked language modeling and next-sentence prediction tasks."
                    },
                    {
                      "id": "rag-003",
                      "text": "Retrieval-Augmented Generation (RAG) grounds language model responses in external knowledge by retrieving relevant documents at inference time."
                    },
                    {
                      "id": "rag-004",
                      "text": "Vector databases index high-dimensional embeddings and use approximate nearest neighbor algorithms like HNSW for fast semantic search."
                    },
                    {
                      "id": "rag-005",
                      "text": "The attention mechanism computes scaled dot-product attention: softmax(QK^T divided by sqrt(d_k)) times V, letting each token attend to all positions."
                    },
                    {
                      "id": "rag-006",
                      "text": "TIBCO Flogo is an open-source ultralight microservices framework that compiles integration flows into single self-contained executable binaries."
                    },
                    {
                      "id": "rag-007",
                      "text": "Cosine similarity measures the angle between two embedding vectors and is the standard distance metric for semantic similarity search."
                    },
                    {
                      "id": "rag-008",

                "useHybridSearch": false,
                "hybridAlpha": 0.5
              },
              "input": {
                "queryText": "How does the attention mechanism work in transformer models?",
                "collectionName": "Ragdemo",
                "topK": 3
              }
            }
          },
          {
            "id": "HybridSearch",
            "name": "HybridSearch",
            "description": "BM25+dense hybrid search (Weaviate native) using query embedding from RAGQuery",
            "activity": {
              "ref": "#hybridSearch",
              "settings": {
                "connection": "conn://weaviate-conn",
                "defaultTopK": 3
              },
              "input": {
                "collectionName": "Ragdemo",
                "queryText": "What is retrieval augmented generation and how does it work",

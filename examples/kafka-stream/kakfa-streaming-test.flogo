{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/milindpandav/flogo-extensions/kafkastream/trigger/aggregate",
    "github.com/milindpandav/flogo-extensions/kafkastream/trigger/filter",
    "github.com/milindpandav/flogo-extensions/kafkastream/trigger/join",
    "github.com/milindpandav/flogo-extensions/kafkastream/trigger/split",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string",
    "github.com/tibco/wi-plugins/contributions/kafka/src/app/Kafka/connector/kafka"
  ],
  "name": "kakfa-streaming-test",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#aggregate",
      "name": "kafka-stream-aggregate-trigger",
      "description": "Consumes messages from a Kafka topic, accumulates a numeric field into a stateful window, and fires the flow when the window closes (tumbling) or on every message (sliding). Supports keyed windows, event-time watermarks, late-event DLQ routing, overflow policies, MessageID deduplication, idle-timeout auto-close, and state persistence.",
      "settings": {
        "kafkaConnection": "conn://1d56a409-8777-475e-a91c-07ad312336c9",
        "topic": "demo",
        "consumerGroup": "demo-aggregate-cg",
        "initialOffset": "newest",
        "balanceStrategy": "roundrobin",
        "windowName": "aggregate-demo-window",
        "windowType": "TumblingTime",
        "windowSize": 5,
        "function": "sum",
        "valueField": "tempreture",
        "keyField": "",
        "eventTimeField": "",
        "messageIDField": "",
        "allowedLateness": 0,
        "maxBufferSize": 0,
        "overflowPolicy": "drop_oldest",
        "idleTimeoutMs": 0,
        "maxKeys": 0,
        "persistPath": "",
        "persistEveryN": 0,
        "commitOnSuccess": true,
        "handlerTimeoutMs": 0,
        "onSchemaError": "skip"
      },
      "id": "AggregateKafkaStreamTrigger",
      "handlers": [
        {
          "description": "",
          "settings": {
            "eventType": "windowClose"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:AggregateKafkaStream"
            },
            "input": {
              "windowResult": "=$.windowResult",
              "source": "=$.source"
            }
          },
          "schemas": {
            "output": {
              "windowResult": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"number\"},\"count\":{\"type\":\"integer\"},\"windowName\":{\"type\":\"string\"},\"key\":{\"type\":\"string\"},\"windowClosed\":{\"type\":\"boolean\"},\"droppedCount\":{\"type\":\"integer\"},\"lateEventCount\":{\"type\":\"integer\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"number\"},\"count\":{\"type\":\"integer\"},\"windowName\":{\"type\":\"string\"},\"key\":{\"type\":\"string\"},\"windowClosed\":{\"type\":\"boolean\"},\"droppedCount\":{\"type\":\"integer\"},\"lateEventCount\":{\"type\":\"integer\"}}}"
              },
              "source": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"partition\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"lateEvent\":{\"type\":\"boolean\"},\"lateReason\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"partition\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"lateEvent\":{\"type\":\"boolean\"},\"lateReason\":{\"type\":\"string\"}}}"
              }
            }
          },
          "name": "AggregateKafkaStream"
        }
      ]
    },
    {
      "ref": "#filter",
      "name": "kafka-stream-filter-trigger",
      "description": "Consumes messages from a Kafka topic and fires the flow only for messages that satisfy the configured predicate(s). Supports single-predicate and multi-predicate AND/OR evaluation, opt-in deduplication, and opt-in rate limiting. The trigger owns its Kafka transport (consumer group) — no separate Kafka trigger is needed.",
      "settings": {
        "kafkaConnection": "conn://1d56a409-8777-475e-a91c-07ad312336c9",
        "topic": "demo",
        "consumerGroup": "demo-filter-cg",
        "initialOffset": "newest",
        "operator": "eq",
        "predicateMode": "and",
        "passThroughOnMissing": false,
        "enableDedup": false,
        "dedupWindow": "10m",
        "dedupMaxEntries": 100000,
        "rateLimitRPS": 0,
        "rateLimitBurst": 0,
        "rateLimitMode": "drop",
        "rateLimitMaxWaitMs": 500,
        "balanceStrategy": "roundrobin",
        "commitOnSuccess": true,
        "handlerTimeoutMs": 0,
        "dedupPersistEveryN": 0
      },
      "id": "FilterKafkaStreamTrigger",
      "handlers": [
        {
          "description": "",
          "settings": {
            "eventType": "pass",
            "field": "tempreture",
            "operator": "gt",
            "value": "25",
            "predicates": "",
            "dedupField": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:FilterKafkaStream"
            },
            "input": {
              "offset": "=$.offset",
              "key": "=$.key",
              "partition": "=$.partition",
              "topic": "=$.topic",
              "message": "=$.message"
            }
          },
          "name": "FilterKafkaStream"
        }
      ]
    },
    {
      "ref": "#join",
      "name": "kafka-stream-join-trigger",
      "description": "Joins demo-readings and demo-alerts on device_id within a 30 s window.",
      "settings": {
        "kafkaConnection": "conn://1d56a409-8777-475e-a91c-07ad312336c9",
        "topics": "demo-readings,demo-alerts",
        "consumerGroup": "demo-join-cg",
        "joinKeyField": "device_id",
        "joinWindowMs": 30000,
        "initialOffset": "newest",
        "balanceStrategy": "roundrobin",
        "commitOnSuccess": true,
        "handlerTimeoutMs": 5000,
        "storeType": "memory"
      },
      "id": "JoinKafkaStreams",
      "handlers": [
        {
          "description": "",
          "settings": {
            "eventType": "joined"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:JoinKafkaStreams"
            },
            "input": {
              "joinResult": "=$.joinResult",
              "timeoutResult": "=$.timeoutResult",
              "eventType": "=$.eventType"
            }
          },
          "schemas": {
            "output": {
              "joinResult": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"messages\":{\"type\":\"object\",\"description\":\"Map of topic name to full decoded JSON payload from that topic.\"},\"joinKey\":{\"type\":\"string\"},\"topics\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"joinedAt\":{\"type\":\"integer\",\"description\":\"Unix-ms wall-clock time when the join completed.\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"messages\":{\"type\":\"object\",\"description\":\"Map of topic name to full decoded JSON payload from that topic.\"},\"joinKey\":{\"type\":\"string\"},\"topics\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"joinedAt\":{\"type\":\"integer\",\"description\":\"Unix-ms wall-clock time when the join completed.\"}}}"
              },
              "timeoutResult": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"partialMessages\":{\"type\":\"object\",\"description\":\"Map of topic name to payload for topics that contributed before timeout.\"},\"joinKey\":{\"type\":\"string\"},\"missingTopics\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"createdAt\":{\"type\":\"integer\",\"description\":\"Unix-ms time when the join window was first opened.\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"partialMessages\":{\"type\":\"object\",\"description\":\"Map of topic name to payload for topics that contributed before timeout.\"},\"joinKey\":{\"type\":\"string\"},\"missingTopics\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"createdAt\":{\"type\":\"integer\",\"description\":\"Unix-ms time when the join window was first opened.\"}}}"
              }
            }
          },
          "name": "JoinKafkaStreams"
        }
      ]
    },
    {

{
    "name": "tibco-rule-engine",
    "title": "Rule Engine",
    "version": "1.0.0",
    "type": "flogo:activity",
    "description": "Generic YAML-driven document analysis engine. Evaluates externalized rules against any structured document (JSON, XML, YAML, key-value, text lines) and returns structured findings.",
    "ref": "github.com/mpandav-tibco/flogo-custom-extensions/activity/ruleengine",
    "display": {
        "category": "Default",
        "visible": true,
        "smallIcon": "icons/ruleengine.svg",
        "largeIcon": "icons/ruleengine.svg",
        "description": "Evaluate YAML rules against structured documents — JSON, XML, YAML, config files, logs"
    },
    "settings": [
        {
            "name": "defaultRulesPath",
            "type": "string",
            "required": false,
            "display": {
                "description": "Default directory path to load rules from when the rulesPath input is empty at runtime. Allows a bundled rule set to be overridden per-invocation."
            }
        }
    ],
    "inputs": [
        {
            "name": "content",
            "type": "string",
            "required": true
        },
        {
            "name": "fileName",
            "type": "string",
            "required": true
        },
        {
            "name": "rulesPath",
            "type": "string",
            "required": false
        },
        {
            "name": "parserOverride",
            "type": "string",
            "required": false,
            "allowed": [
                "",
                "json",
                "xml",
                "yaml",
                "kv",
                "lines"
            ]
        },
        {
            "name": "disabledRules",
            "type": "array",
            "required": false,
            "items": {
                "type": "string"
            }
        },
        {
            "name": "tags",
            "type": "array",
            "required": false,
            "items": {
                "type": "string"
            }
        }
    ],
    "output": [
        {
            "name": "findings",
            "type": "array",
            "description": "Array of issue/warning findings from matched rules",
            "items": {
                "type": "object",
                "properties": {
                    "rule_id": {
                        "type": "string"
                    },
                    "severity": {
                        "type": "string"
                    },
                    "category": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "recommendation": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "root_causes": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "fixes": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        {
            "name": "positives",
            "type": "array",
            "description": "Array of positive/strength findings (GOOD severity rules)",
            "items": {
                "type": "object",
                "properties": {
                    "rule_id": {
                        "type": "string"
                    },
                    "severity": {
                        "type": "string"
                    },
                    "category": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "recommendation": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        {
            "name": "errorCount",
            "type": "integer",
            "description": "Number of ERROR severity findings"
        },
        {
            "name": "warningCount",
            "type": "integer",
            "description": "Number of WARNING severity findings"
        },
        {
            "name": "infoCount",
            "type": "integer",
            "description": "Number of INFO severity findings"
        },
        {
            "name": "goodCount",
            "type": "integer",
            "description": "Number of GOOD severity findings (strengths)"
        },
        {
            "name": "markdown",
            "type": "string",
            "description": "Pre-formatted markdown analysis report"
        },
        {
            "name": "overview",
            "type": "object",
            "description": "Parsed document overview (name, item counts, structure summary)"
        },
        {
            "name": "success",
            "type": "boolean",
            "description": "True if evaluation completed without errors"
        },
        {
            "name": "error",
            "type": "string",
            "description": "Error message if success is false"
        }
    ]
}